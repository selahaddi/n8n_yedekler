    {
      "parameters": {
        "jsCode": "const results = [];\n\n// n8n'den gelen her bir iş akışını tek tek döngüye al\nfor (const item of $input.all()) {\n  const workflowData = item.json;\n\n  // 1. Dosya adı oluşturma: İş akışı adındaki Türkçe karakterleri ve boşlukları temizle\n  let safeName = workflowData.name \n    ? workflowData.name.replace(/[^a-z0-9]/gi, '_').toLowerCase() \n    : 'is_akisi';\n    \n  // 2. Çakışmayı önlemek için sonuna iş akışı ID'sini ekle\n  const fileName = `workflows1/${safeName}_${workflowData.id}.json`;\n\n  // 3. İş akışını n8n'in doğrudan okuyabileceği (Import edilebilir) JSON metnine çevir\n  const fileContent = JSON.stringify(workflowData, null, 2);\n\n  // 4. Her iş akışını ayrı bir öğe (item) olarak GitHub node'una gönder\n  results.push({\n    json: {\n      dosya_adi: fileName,\n      dosya_icerigi: fileContent,\n      orijinal_isim: workflowData.name\n    }\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
