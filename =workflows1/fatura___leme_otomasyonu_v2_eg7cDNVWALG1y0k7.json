            "Tedarikçi VKN": "={{ $json.tedarikci_vkn }}",
            "Vergi Dairesi": "={{ $json.tedarikci_vergi_dairesi }}",
            "Ara Toplam": "={{ $json.ara_toplam }}",
            "KDV Oranı (%)": "={{ $json.kdv_orani }}",
            "KDV Tutarı": "={{ $json.kdv_tutari }}",
