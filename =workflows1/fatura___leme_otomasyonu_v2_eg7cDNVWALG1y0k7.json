    {
      "parameters": {
        "jsCode": "// PDF eki olmayan e-postalar için bilgi logu\nconst info = {\n  json: {\n    durum: 'ℹ️ BİLGİ',\n    mesaj: items[0].json.message || 'E-postada PDF eki bulunamadı',\n    email_konu: items[0].json.emailSubject || 'Konu Yok',\n    email_gonderen: items[0].json.emailFrom || 'Bilinmeyen',\n    islem_zamani: new Date().toLocaleString('tr-TR', { timeZone: 'Europe/Istanbul' })\n  }\n};\n\nreturn [info];"
