          }
        },
        "options": {}
      },
      "id": "f93ea14a-eeb9-4ef7-a376-82e6f8c6d3ef",
      "name": "📊 Google Sheets'e Kaydet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        240,
        -128
      ],
      "notes": "Çıkarılan fatura verilerini Google Sheets'e yeni satır olarak ekler. 15 sütun: Fatura No, Tarih, Tedarikçi, VKN, Vergi Dairesi, Ara Toplam, KDV Oranı, KDV Tutarı, Toplam, Para Birimi, Tip, Açıklama, Dosya, Gönderen, İşlenme Zamanı."
    },
    {
      "parameters": {
        "jsCode": "// Başarılı işleme logu oluştur\nconst logEntry = {\n  json: {\n    durum: '✅ BAŞARILI',\n    fatura_no: items[0].json.fatura_no || 'N/A',\n    tedarikci: items[0].json.tedarikci_adi || 'N/A',\n    toplam: items[0].json.toplam_tutar || 'N/A',\n    islem_zamani: new Date().toLocaleString('tr-TR', { timeZone: 'Europe/Istanbul' }),\n    mesaj: `Fatura başarıyla işlendi ve Google Sheets'e kaydedildi.`\n  }\n};\n\nreturn [logEntry];"
      },
      "id": "b2a1ecc8-7647-4efe-a9c6-2956c4ad8b93",
      "name": "📝 Başarı Logu",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        -128
      ],
      "notes": "Başarılı işleme sonrası log kaydı oluşturur."
    },
    {
      "parameters": {
        "jsCode": "// Hata bildirim mesajı oluştur\nconst errorInfo = {\n  json: {\n    durum: '❌ HATA',\n    hata_detay: items[0].json._meta?.hata || 'Veri doğrulama başarısız',\n    dosya_adi: items[0].json._meta?.dosya_adi || 'bilinmeyen',\n    ham_yanit: items[0].json._meta?.ham_yanit || 'Yanıt yok',\n    islem_zamani: new Date().toLocaleString('tr-TR', { timeZone: 'Europe/Istanbul' }),\n    mesaj: 'Fatura otomatik olarak işlenemedi. Lütfen manuel kontrol edin.',\n    email_konu: items[0].json._meta?.email_konu || '',\n    email_gonderen: items[0].json._meta?.email_gonderen || ''\n  }\n};\n\nreturn [errorInfo];"
      },
      "id": "1fb12200-4d53-4582-a181-7ec5cf5ee13e",
