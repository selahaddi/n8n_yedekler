    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"urunler\": [\n    {\n      \"urun_kodu\": \"UR-001\",\n      \"urun_adi\": \"Tam Yağlı Süt 1L\",\n      \"kategori\": \"Süt Ürünleri\",\n      \"tedarikci\": \"Pınar Gıda\",\n      \"mevcut_stok\": 10,\n      \"minimum_stok\": 30,\n      \"son_30_gun_satis\": 120,\n      \"birim_fiyat\": 38.50,\n      \"siparis_durumu\": \"SİPARİŞ VER\",\n      \"siparis_adedi\": 170,\n      \"tahmini_maliyet\": 6545.00,\n      \"oncelik\": \"ACİL\",\n      \"sebep\": \"Stok kritik seviyenin altında, 30 günlük talep karşılanamaz.\",\n      \"depo_bolgesi\": \"Soğuk Hava\",\n      \"koridor\": \"A\",\n      \"raf_no\": 3,\n      \"yerlesim_gerekcesi\": \"Çok satan (A grubu) soğuk zincir ürünü, göz hizasında tutulmalı.\"\n    }\n  ]\n}"
      },
      "id": "30f24b86-0fb5-42ee-83ce-aa416db1507a",
      "name": "Structured Output Parser1",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        640,
        784
      ]
    },
    {
      "parameters": {
        "jsCode": "// AI Agent çıktısını normalize et\nconst items = [];\n\nfor (const item of $input.all()) {\n  try {\n    const data = item.json.output || item.json;\n\n    if (data.urunler && Array.isArray(data.urunler)) {\n      for (const product of data.urunler) {\n        items.push({ json: product });\n      }\n    } else if (Array.isArray(data)) {\n      for (const product of data) {\n        items.push({ json: product });\n      }\n    } else if (data.urun_kodu) {\n      items.push({ json: data });\n    } else {\n      let content = typeof data === 'string' ? data : JSON.stringify(data);\n      content = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n      const jsonMatch = content.match(/\\[\\s*\\{[\\s\\S]*\\}\\s*\\]/);\n      if (jsonMatch) content = jsonMatch[0];\n      const parsed = JSON.parse(content);\n      if (Array.isArray(parsed)) {\n        for (const p of parsed) items.push({ json: p });\n      } else {\n        items.push({ json: parsed });\n      }\n    }\n  } catch (error) {\n    items.push({\n      json: {\n        hata: 'JSON parse hatası',\n        ham_cevap: JSON.stringify(item.json).substring(0, 500),\n        hata_detay: error.message\n      }\n    });\n  }\n}\n\nreturn items;"
      },
      "id": "4dc4108d-a4ba-4824-b054-0c6553aeb734",
      "name": "AI Cevabını İşle1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        544
      ]
    },
    {
      "parameters": {
        "jsCode": "// Tüm döngü adımlarında işlenen verileri topla\nconst tum_urunler = [];\n\n// Node isminden tüm çalışmalardaki verileri çek\n// 0: input index, -1: tüm run'ları (0-N) temsil eder\ntry {\n  const allRuns = $items('AI Cevabını İşle1', 0, -1);\n  for (const item of allRuns) {\n    if (item.json) {\n      // Sadece asıl verileri al, hata mesajlarını atla\n      if(!item.json.hata) {\n         tum_urunler.push(item.json);\n      }\n    }\n  }\n} catch(e) {\n  console.log('Veriler toplanırken hata:', e);\n}\n\nreturn [{ json: { tum_urunler } }];"
      },
      "id": "0341ea15-85fc-47f8-8056-deafec714d30",
      "name": "Tüm Sonuçları Topla1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        544,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "// Tüm ürünleri al\nconst urunler = $input.first().json.tum_urunler || [];\n\n// ─── Sipariş listesi (sadece sipariş verilecekler) ───\nconst siparisListesi = urunler\n  .filter(u => u.siparis_durumu === 'SİPARİŞ VER')\n  .sort((a, b) => {\n    const oncelik = { 'ACİL': 0, 'NORMAL': 1, 'YOK': 2 };\n    return (oncelik[a.oncelik] ?? 2) - (oncelik[b.oncelik] ?? 2);\n  });\n\n// ─── Özet istatistikler ───\nconst acilSayisi = urunler.filter(u => u.oncelik === 'ACİL').length;\nconst normalSayisi = urunler.filter(u => u.oncelik === 'NORMAL').length;\nconst yeterliSayisi = urunler.filter(u => u.siparis_durumu === 'STOK YETERLİ').length;\nconst toplamMaliyet = siparisListesi.reduce((s, u) => s + (u.tahmini_maliyet || 0), 0);\n\n// ─── Kategori özeti ───\nconst kategoriOzeti = {};\nfor (const u of urunler) {\n  const kat = u.kategori || 'Diğer';\n  if (!kategoriOzeti[kat]) kategoriOzeti[kat] = { acil: 0, normal: 0, yeterli: 0, maliyet: 0 };\n  if (u.oncelik === 'ACİL') kategoriOzeti[kat].acil++;\n  else if (u.oncelik === 'NORMAL') kategoriOzeti[kat].normal++;\n  else kategoriOzeti[kat].yeterli++;\n  kategoriOzeti[kat].maliyet += u.tahmini_maliyet || 0;\n}\n\n// ─── Tedarikçi gruplandırması ───\nconst tedarikciOzeti = {};\nfor (const u of siparisListesi) {\n  const ted = u.tedarikci || 'Bilinmiyor';\n  if (!tedarikciOzeti[ted]) tedarikciOzeti[ted] = { urunler: [], toplamMaliyet: 0 };\n  tedarikciOzeti[ted].urunler.push(u.urun_adi);\n  tedarikciOzeti[ted].toplamMaliyet += u.tahmini_maliyet || 0;\n}\n\n// ─── Depo yerleşim özeti ───\nconst depoOzeti = {};\nfor (const u of urunler) {\n  const bolge = u.depo_bolgesi || 'Bilinmiyor';\n  if (!depoOzeti[bolge]) depoOzeti[bolge] = [];\n  depoOzeti[bolge].push({ urun: u.urun_adi, koridor: u.koridor, raf: u.raf_no });\n}\n\n// ─── Çıktıyı döndür ───\nreturn [{\n  json: {\n    siparis_listesi: siparisListesi,\n    tum_urunler: urunler,\n    ozet: {\n      toplam_urun: urunler.length,\n      acil_siparis: acilSayisi,\n      normal_siparis: normalSayisi,\n      stok_yeterli: yeterliSayisi,\n      tahmini_toplam_maliyet: Math.round(toplamMaliyet * 100) / 100\n    },\n    kategori_ozeti: Object.entries(kategoriOzeti).map(([kat, v]) => ({\n      kategori: kat, ...v, maliyet: Math.round(v.maliyet)\n    })),\n    tedarikci_ozeti: Object.entries(tedarikciOzeti).map(([ted, v]) => ({\n      tedarikci: ted,\n      urun_sayisi: v.urunler.length,\n      urunler: v.urunler.join(', '),\n      toplam_maliyet: Math.round(v.toplamMaliyet)\n    })),\n    depo_ozeti: depoOzeti\n  }\n}];"
      },
      "id": "2df91e8b-c87c-4d42-ae38-ae9e35e355f9",
      "name": "Dashboard & Excel Hazırla1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        784,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "// Sipariş listesi sayfası için satır formatla\nconst data = $input.first().json;\nconst rows = [];\n\nfor (const u of data.siparis_listesi) {\n  rows.push({\n    'Öncelik': u.oncelik,\n    'Ürün Kodu': u.urun_kodu,\n    'Ürün Adı': u.urun_adi,\n    'Kategori': u.kategori,\n    'Tedarikçi': u.tedarikci,\n    'Mevcut Stok': u.mevcut_stok,\n    'Min. Stok': u.minimum_stok,\n    'Son 30 Gün Satış': u.son_30_gun_satis,\n    'Sipariş Adedi': u.siparis_adedi,\n    'Birim Fiyat (TL)': u.birim_fiyat,\n    'Tahmini Maliyet (TL)': u.tahmini_maliyet,\n    'Sebep': u.sebep,\n    'Depo Bölgesi': u.depo_bolgesi,\n    'Koridor': u.koridor,\n    'Raf No': u.raf_no\n  });\n}\n\nreturn rows.map(r => ({ json: r }));"
      },
      "id": "f1767f9b-aa52-4690-b901-978d2d537ebd",
      "name": "Sipariş Listesi Excel1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1024,
        -48
      ]
    },
    {
      "parameters": {
        "jsCode": "// Dashboard özet satırları\nconst data = $input.first().json;\nconst rows = [];\n\n// Genel özet\nrows.push({ 'Bölüm': '=== GENEL ÖZET ===', 'Metrik': '', 'Değer': '' });\nrows.push({ 'Bölüm': 'Genel', 'Metrik': 'Toplam Ürün Sayısı', 'Değer': data.ozet.toplam_urun });\nrows.push({ 'Bölüm': 'Genel', 'Metrik': '🔴 Acil Sipariş Gereken', 'Değer': data.ozet.acil_siparis });\nrows.push({ 'Bölüm': 'Genel', 'Metrik': '🟡 Normal Sipariş Gereken', 'Değer': data.ozet.normal_siparis });\nrows.push({ 'Bölüm': 'Genel', 'Metrik': '🟢 Stok Yeterli', 'Değer': data.ozet.stok_yeterli });\nrows.push({ 'Bölüm': 'Genel', 'Metrik': '💰 Tahmini Toplam Sipariş Maliyeti (TL)', 'Değer': data.ozet.tahmini_toplam_maliyet });\nrows.push({ 'Bölüm': '', 'Metrik': '', 'Değer': '' });\n\n// Kategori özeti\nrows.push({ 'Bölüm': '=== KATEGORİ BAZLI ÖZET ===', 'Metrik': '', 'Değer': '' });\nrows.push({ 'Bölüm': 'Kategori', 'Metrik': 'Acil | Normal | Yeterli | Maliyet (TL)', 'Değer': '' });\nfor (const k of data.kategori_ozeti) {\n  rows.push({\n    'Bölüm': k.kategori,\n    'Metrik': `Acil: ${k.acil} | Normal: ${k.normal} | Yeterli: ${k.yeterli}`,\n    'Değer': k.maliyet\n  });\n}\nrows.push({ 'Bölüm': '', 'Metrik': '', 'Değer': '' });\n\n// Tedarikçi özeti\nrows.push({ 'Bölüm': '=== TEDARİKÇİ BAZLI SİPARİŞ ===', 'Metrik': '', 'Değer': '' });\nrows.push({ 'Bölüm': 'Tedarikçi', 'Metrik': 'Ürünler', 'Değer': 'Toplam Maliyet (TL)' });\nfor (const t of data.tedarikci_ozeti) {\n  rows.push({\n    'Bölüm': `${t.tedarikci} (${t.urun_sayisi} ürün)`,\n    'Metrik': t.urunler,\n    'Değer': t.toplam_maliyet\n  });\n}\n\nreturn rows.map(r => ({ json: r }));"
      },
