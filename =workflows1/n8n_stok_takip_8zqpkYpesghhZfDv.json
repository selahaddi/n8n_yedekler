    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst tum_urunler = [];\n\nfor (const item of items) {\n  const data = item.json;\n  \n  const mevcut_stok = data.mevcut_stok || 0;\n  const minimum_stok = data.minimum_stok || 0;\n  const son_30_gun_satis = data.son_30_gun_satis || 0;\n  const birim_fiyat = data.birim_fiyat || 0;\n  \n  // Safely lowercase strings\n  const urun_adi = (data.urun_adi || \"\").toString().toLowerCase();\n  const kategori = (data.kategori || \"\").toString().toLowerCase();\n  \n  let siparis_durumu = \"STOK YETERLİ\";\n  let oncelik = \"YOK\";\n  let sebep = \"Stok güvenli seviyede.\";\n  \n  if (mevcut_stok < minimum_stok) {\n    siparis_durumu = \"SİPARİŞ VER\";\n    oncelik = \"ACİL\";\n    sebep = \"Kritik seviyenin altında.\";\n  } else if (mevcut_stok < minimum_stok * 1.5) {\n    siparis_durumu = \"SİPARİŞ VER\";\n    oncelik = \"NORMAL\";\n    sebep = \"Güvenli seviyenin altında.\";\n  }\n  \n  let siparis_adedi = 0;\n  let tahmini_maliyet = 0;\n  \n  if (siparis_durumu === \"SİPARİŞ VER\") {\n    siparis_adedi = Math.max(0, Math.ceil((son_30_gun_satis * 1.5) - mevcut_stok));\n    tahmini_maliyet = siparis_adedi * birim_fiyat;\n  }\n  \n  let depo_bolgesi = \"Kuru Gıda\";\n  if (kategori.includes(\"süt\") || kategori.includes(\"yoğurt\") || kategori.includes(\"peynir\") || kategori.includes(\"et\") || kategori.includes(\"tavuk\") || urun_adi.includes(\"süt\") || urun_adi.includes(\"tavuk\")) {\n    depo_bolgesi = \"Soğuk Hava\";\n  } else if (kategori.includes(\"deterjan\") || kategori.includes(\"temizlik\") || kategori.includes(\"sabun\") || kategori.includes(\"kimyasal\")) {\n    depo_bolgesi = \"Kimyasal\";\n  }\n  \n  let koridor = \"C\";\n  if (son_30_gun_satis > 100) {\n    koridor = \"A\";\n  } else if (son_30_gun_satis >= 50) {\n    koridor = \"B\";\n  }\n  \n  let raf_no = 3;\n  // Ağırlık/Boyut tahminleri ile raf no belirleme\n  const isHeavy = urun_adi.match(/[5-9]\\s*(kg|lt|litre)/i) || urun_adi.match(/[1-9][0-9]\\s*(kg|lt|litre)/i) || kategori.includes(\"deterjan\") || urun_adi.includes(\"un \") || urun_adi.includes(\"şeker\");\n  if (isHeavy) {\n    raf_no = 1;\n  } else if (son_30_gun_satis < 20) {\n    raf_no = 4;\n  }\n  \n  tum_urunler.push({\n    ...data,\n    siparis_durumu,\n    oncelik,\n    sebep,\n    siparis_adedi,\n    tahmini_maliyet,\n    depo_bolgesi,\n    koridor,\n    raf_no,\n    yerlesim_gerekcesi: `Grup: ${depo_bolgesi}, Hız: ${koridor}, Raf: ${raf_no}`\n  });\n}\n\nreturn [{ json: { tum_urunler } }];"
      },
