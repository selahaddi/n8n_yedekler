    {
      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════\n// GÖREV 1 — SİPARİŞ ANALİZİ  (kural tabanlı)\n// ═══════════════════════════════════════════════════\nconst items = $input.all();\nconst result = [];\n\nfor (const item of items) {\n  const d = item.json;\n\n  const mevcut   = Number(d.mevcut_stok)       || 0;\n  const minStok  = Number(d.minimum_stok)       || 0;\n  const satis30  = Number(d.son_30_gun_satis)   || 0;\n  const fiyat    = Number(d.birim_fiyat)        || 0;\n\n  let siparis_durumu, oncelik, sebep;\n\n  if (mevcut < minStok) {\n    siparis_durumu = \"SİPARİŞ VER\";\n    oncelik        = \"ACİL\";\n    sebep          = \"Stok kritik seviyenin altında, 30 günlük talep karşılanamaz.\";\n  } else if (mevcut < minStok * 1.5) {\n    siparis_durumu = \"SİPARİŞ VER\";\n    oncelik        = \"NORMAL\";\n    sebep          = \"Stok güvenli bandın altına düşmek üzere.\";\n  } else {\n    siparis_durumu = \"STOK YETERLİ\";\n    oncelik        = \"YOK\";\n    sebep          = \"Stok yeterli seviyede.\";\n  }\n\n  const siparis_adedi    = siparis_durumu === \"SİPARİŞ VER\"\n                             ? Math.max(0, Math.ceil(satis30 * 1.5 - mevcut))\n                             : 0;\n  const tahmini_maliyet  = Math.round(siparis_adedi * fiyat * 100) / 100;\n\n  result.push({\n    json: {\n      ...d,\n      siparis_durumu,\n      siparis_adedi,\n      tahmini_maliyet,\n      oncelik,\n      sebep\n    }\n  });\n}\n\nreturn result;\n"
      },
      "id": "ea7a298f-b87e-4eb3-b9e3-5a07f045774c",
      "name": "Sipariş Analizi",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -16,
        2464
      ]
    },
    {
      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════\n// GÖREV 2 — DEPO YERLEŞİMİ  (ABC Analizi, kural tabanlı)\n// ═══════════════════════════════════════════════════\nconst items = $input.all();\nconst result = [];\n\n// Soğuk hava anahtar kelimeleri (kategori veya ürün adı)\nconst sogukKelimeler  = [\"süt\",\"yoğurt\",\"peynir\",\"et \",\"tavuk\",\"kıyma\",\"sosis\",\n                          \"salam\",\"kaşar\",\"beyaz peynir\",\"ayran\",\"kefir\",\"tereyağ\"];\n// Kimyasal anahtar kelimeleri\nconst kimyasalKelimeler = [\"deterjan\",\"çamaşır\",\"sabun\",\"temizlik\",\"çamaşır suyu\",\n                            \"bulaşık\",\"yumuşatıcı\",\"dezenfektan\"];\n// Ağır ürünler -> Raf 1 (Zemin)\nconst agirKelimeler = [\"bidon\",\"teneke\",\"un \",\"şeker\",\"yağ \",\"5 kg\",\"10 kg\",\n                        \"5kg\",\"10kg\",\"5 lt\",\"10 lt\",\"5lt\",\"10lt\",\"25 kg\",\"25kg\"];\n\nfor (const item of items) {\n  const d = item.json;\n\n  const urunAdi  = (d.urun_adi  || \"\").toLowerCase();\n  const kategori = (d.kategori  || \"\").toLowerCase();\n  const satis30  = Number(d.son_30_gun_satis) || 0;\n\n  // ── Depo Bölgesi ──\n  let depo_bolgesi = \"Kuru Gıda\";\n  if (sogukKelimeler.some(k => kategori.includes(k) || urunAdi.includes(k))) {\n    depo_bolgesi = \"Soğuk Hava\";\n  } else if (kimyasalKelimeler.some(k => kategori.includes(k) || urunAdi.includes(k))) {\n    depo_bolgesi = \"Kimyasal\";\n  }\n\n  // ── Koridor (ABC) ──\n  let koridor;\n  if (satis30 > 100)       koridor = \"A\";\n  else if (satis30 >= 50)  koridor = \"B\";\n  else                     koridor = \"C\";\n\n  // ── Raf Numarası ──\n  let raf_no = 3;  // Varsayılan: Göz hizası (popüler & hafif)\n  const isAgir = agirKelimeler.some(k => urunAdi.includes(k));\n  if (isAgir) {\n    raf_no = 1;   // Zemin — ağır ürünler\n  } else if (satis30 < 50 && koridor === \"C\") {\n    raf_no = 4;   // Üst raf — az satılan / çok hafif\n  }\n\n  // ── Yerleşim Gerekçesi ──\n  const koridorAciklama = {A:\"Giriş / Hızlı Erişim\", B:\"Orta Bölge\", C:\"Arka / Yavaş Bölge\"};\n  const rafAciklama     = {1:\"Zemin (ağır)\", 3:\"Göz hizası (popüler)\", 4:\"Üst raf (hafif/az satan)\", 5:\"En üst raf\"};\n  const yerlesim_gerekcesi =\n    `${depo_bolgesi} bölgesi, Koridor ${koridor} (${koridorAciklama[koridor]}), ` +\n    `Raf ${raf_no} (${rafAciklama[raf_no] || \"Standart\"}).`;\n\n  result.push({\n    json: {\n      ...d,\n      depo_bolgesi,\n      koridor,\n      raf_no,\n      yerlesim_gerekcesi\n    }\n  });\n}\n\nreturn result;\n"
      },
      "id": "1e62ede7-dd10-4a92-95b1-3a278af6895a",
      "name": "Depo Yerleşimi",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        2464
      ]
    },
    {
      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════\n// Tüm ürünleri tek bir JSON nesnesine topla\n// (Dashboard & Excel Hazırla düğümü bu formatı bekliyor)\n// ═══════════════════════════════════════════════════\nconst items = $input.all();\nconst tum_urunler = items.map(i => i.json);\n\nreturn [{ json: { tum_urunler } }];\n"
      },
