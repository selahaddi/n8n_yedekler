      "parameters": {
        "jsCode": "// ============================================================\n// STARTIQ — Report Generator: DOCX + HTML Webpage\n// Pure built-in JS — no external libraries\n// Runs AFTER Merge node — reads all 4 LLM chain outputs\n// ============================================================\n\nconst items = $input.all();\n\nconst sections = items.map(item =>\n  item.json.text || item.json.output || item.json.response ||\n  item.json.message || JSON.stringify(item.json)\n);\nconst fullText = sections.join('\\n\\n');\n\nconst date = new Date().toLocaleDateString('en-IN', {\n  year: 'numeric', month: 'long', day: 'numeric'\n});\nconst safeDate = new Date().toISOString().split('T')[0];\n\nconst xmlEsc = s => String(s)\n  .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')\n  .replace(/\"/g,'&quot;').replace(/'/g,'&apos;');\n\nconst detectStyle = line => {\n  if (!line.trim()) return 'empty';\n  if (/^[\\d\\u20E3\\uFE0F]{1,4}\\s/.test(line) ||\n      /^[A-Z][A-Z\\s\\&\\/\\-\\.]{10,}$/.test(line) ||\n      /\\*\\*[A-Z0-9]/.test(line)) return 'h1';\n  if (/^[A-Z][^a-z]{0,60}:$/.test(line)) return 'h2';\n  if (/score[:\\s(]/i.test(line) || /\\d\\/10/.test(line)) return 'score';\n  if (/^[-\\u2022\\*]\\s/.test(line) || /^\\d+\\.\\s/.test(line)) return 'bullet';\n  return 'body';\n};\n\n// ============================================================\n// 1. BUILD DOCX (Office Open XML — pure ZIP)\n// ============================================================\nconst enc = new TextEncoder();\n\nconst crc32 = buf => {\n  const t = [];\n  for (let i=0;i<256;i++){let k=i;for(let j=0;j<8;j++){k=k&1?(0xEDB88320^(k>>>1)):k>>>1;}t[i]=k;}\n  let c=0xFFFFFFFF;\n  for (let i=0;i<buf.length;i++) c=t[(c^buf[i])&0xFF]^(c>>>8);\n  return (c^0xFFFFFFFF)>>>0;\n};\n\nconst makeDocxPara = (text, style) => {\n  const clean = xmlEsc(text.replace(/\\*\\*/g,'').trim());\n  if (!clean) return '<w:p><w:pPr><w:spacing w:after=\"80\"/></w:pPr></w:p>';\n  switch(style) {\n    case 'title':\n      return `<w:p><w:pPr><w:jc w:val=\"center\"/><w:spacing w:before=\"0\" w:after=\"200\"/></w:pPr><w:r><w:rPr><w:b/><w:sz w:val=\"52\"/><w:color w:val=\"1a1a1a\"/></w:rPr><w:t>${clean}</w:t></w:r></w:p>`;\n    case 'subtitle':\n      return `<w:p><w:pPr><w:jc w:val=\"center\"/><w:spacing w:before=\"0\" w:after=\"160\"/></w:pPr><w:r><w:rPr><w:sz w:val=\"24\"/><w:color w:val=\"888888\"/><w:i/></w:rPr><w:t>${clean}</w:t></w:r></w:p>`;\n    case 'h1':\n      return `<w:p><w:pPr><w:spacing w:before=\"400\" w:after=\"120\"/><w:shd w:val=\"clear\" w:color=\"auto\" w:fill=\"F4F4F4\"/><w:pBdr><w:left w:val=\"single\" w:sz=\"16\" w:space=\"8\" w:color=\"1a1a1a\"/></w:pBdr></w:pPr><w:r><w:rPr><w:b/><w:sz w:val=\"26\"/><w:color w:val=\"1a1a1a\"/></w:rPr><w:t xml:space=\"preserve\"> ${clean}</w:t></w:r></w:p>`;\n    case 'h2':\n      return `<w:p><w:pPr><w:spacing w:before=\"240\" w:after=\"80\"/></w:pPr><w:r><w:rPr><w:b/><w:sz w:val=\"22\"/><w:color w:val=\"333333\"/></w:rPr><w:t>${clean}</w:t></w:r></w:p>`;\n    case 'score':\n      return `<w:p><w:pPr><w:spacing w:before=\"120\" w:after=\"120\"/><w:shd w:val=\"clear\" w:color=\"auto\" w:fill=\"FDF8EC\"/></w:pPr><w:r><w:rPr><w:b/><w:sz w:val=\"22\"/><w:color w:val=\"8B6914\"/></w:rPr><w:t>${clean}</w:t></w:r></w:p>`;\n    case 'bullet':\n      return `<w:p><w:pPr><w:numPr><w:ilvl w:val=\"0\"/><w:numId w:val=\"1\"/></w:numPr><w:spacing w:after=\"80\"/></w:pPr><w:r><w:rPr><w:sz w:val=\"22\"/><w:color w:val=\"333333\"/></w:rPr><w:t>${clean.replace(/^[-\\u2022\\*\\d+\\.\\s]/,'')}</w:t></w:r></w:p>`;\n    default:\n      return `<w:p><w:pPr><w:jc w:val=\"both\"/><w:spacing w:after=\"100\"/></w:pPr><w:r><w:rPr><w:sz w:val=\"22\"/><w:color w:val=\"444444\"/></w:rPr><w:t xml:space=\"preserve\">${clean}</w:t></w:r></w:p>`;\n  }\n};\n\nlet docxParas = '';\ndocxParas += makeDocxPara('STARTIQ — STARTUP IDEA VALIDATION REPORT', 'title');\ndocxParas += makeDocxPara('Institutional-Grade Analysis · 30 Sections', 'subtitle');\ndocxParas += makeDocxPara(`Generated: ${date} · Confidential`, 'subtitle');\ndocxParas += '<w:p><w:pPr><w:spacing w:after=\"200\"/></w:pPr></w:p>';\n\nfor (const rawLine of fullText.split('\\n')) {\n  const line = rawLine.trim();\n  const style = detectStyle(line);\n  if (style === 'empty') {\n    docxParas += '<w:p><w:pPr><w:spacing w:after=\"80\"/></w:pPr></w:p>';\n  } else {\n    docxParas += makeDocxPara(line, style);\n  }\n}\n\nconst numberingXml = `<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><w:numbering xmlns:w=\"http://schemas.openxmlformats.org/wordprocessingml/2006/main\"><w:abstractNum w:abstractNumId=\"0\"><w:lvl w:ilvl=\"0\"><w:start w:val=\"1\"/><w:numFmt w:val=\"bullet\"/><w:lvlText w:val=\"•\"/><w:lvlJc w:val=\"left\"/><w:pPr><w:ind w:left=\"360\" w:hanging=\"360\"/></w:pPr></w:lvl></w:abstractNum><w:num w:numId=\"1\"><w:abstractNumId w:val=\"0\"/></w:num></w:numbering>`;\n\nconst documentXml = `<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><w:document xmlns:w=\"http://schemas.openxmlformats.org/wordprocessingml/2006/main\"><w:body>${docxParas}<w:sectPr><w:pgSz w:w=\"12240\" w:h=\"15840\"/><w:pgMar w:top=\"1440\" w:right=\"1080\" w:bottom=\"1440\" w:left=\"1080\"/></w:sectPr></w:body></w:document>`;\n\nconst stylesXml = `<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><w:styles xmlns:w=\"http://schemas.openxmlformats.org/wordprocessingml/2006/main\"><w:docDefaults><w:rPrDefault><w:rPr><w:rFonts w:ascii=\"Georgia\" w:hAnsi=\"Georgia\"/><w:sz w:val=\"22\"/></w:rPr></w:rPrDefault></w:docDefaults><w:style w:type=\"paragraph\" w:styleId=\"Normal\"><w:name w:val=\"Normal\"/></w:style></w:styles>`;\n\nconst contentTypesXml = `<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Types xmlns=\"http://schemas.openxmlformats.org/package/2006/content-types\"><Default Extension=\"rels\" ContentType=\"application/vnd.openxmlformats-package.relationships+xml\"/><Default Extension=\"xml\" ContentType=\"application/xml\"/><Override PartName=\"/word/document.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.wordprocessingml.document.main+xml\"/><Override PartName=\"/word/styles.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.wordprocessingml.styles+xml\"/><Override PartName=\"/word/numbering.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.wordprocessingml.numbering+xml\"/></Types>`;\n\nconst relsXml = `<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument\" Target=\"word/document.xml\"/></Relationships>`;\n\nconst wordRelsXml = `<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?><Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\"><Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/styles\" Target=\"styles.xml\"/><Relationship Id=\"rId2\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/numbering\" Target=\"numbering.xml\"/></Relationships>`;\n\nconst makeLocal = (name, data) => {\n  const nb=enc.encode(name); const crc=crc32(data);\n  const h=new Uint8Array(30+nb.length); const v=new DataView(h.buffer);\n  v.setUint32(0,0x04034b50,true); v.setUint16(4,20,true); v.setUint16(6,0,true);\n  v.setUint16(8,0,true); v.setUint16(10,0,true); v.setUint16(12,0,true);\n  v.setUint32(14,crc,true); v.setUint32(18,data.length,true); v.setUint32(22,data.length,true);\n  v.setUint16(26,nb.length,true); v.setUint16(28,0,true); h.set(nb,30);\n  const out=new Uint8Array(h.length+data.length); out.set(h); out.set(data,h.length); return out;\n};\nconst makeCD = (name,data,off,crc) => {\n  const nb=enc.encode(name); const cd=new Uint8Array(46+nb.length); const v=new DataView(cd.buffer);\n  v.setUint32(0,0x02014b50,true); v.setUint16(4,20,true); v.setUint16(6,20,true);\n  v.setUint16(8,0,true); v.setUint16(10,0,true); v.setUint16(12,0,true); v.setUint16(14,0,true);\n  v.setUint32(16,crc,true); v.setUint32(20,data.length,true); v.setUint32(24,data.length,true);\n  v.setUint16(28,nb.length,true); v.setUint16(30,0,true); v.setUint16(32,0,true);\n  v.setUint16(34,0,true); v.setUint16(36,0,true); v.setUint32(38,0x20,true);\n  v.setUint32(42,off,true); cd.set(nb,46); return cd;\n};\nconst makeEOCD = (cdSize,cdOff,n) => {\n  const e=new Uint8Array(22); const v=new DataView(e.buffer);\n  v.setUint32(0,0x06054b50,true); v.setUint16(4,0,true); v.setUint16(6,0,true);\n  v.setUint16(8,n,true); v.setUint16(10,n,true); v.setUint32(12,cdSize,true);\n  v.setUint32(16,cdOff,true); v.setUint16(20,0,true); return e;\n};\n\nconst zipFiles = [\n  {name:'[Content_Types].xml',         data:enc.encode(contentTypesXml)},\n  {name:'_rels/.rels',                  data:enc.encode(relsXml)},\n  {name:'word/document.xml',            data:enc.encode(documentXml)},\n  {name:'word/styles.xml',              data:enc.encode(stylesXml)},\n  {name:'word/numbering.xml',           data:enc.encode(numberingXml)},\n  {name:'word/_rels/document.xml.rels', data:enc.encode(wordRelsXml)},\n];\n\nconst locals=[]; const cds=[]; let zipOff=0;\nfor (const f of zipFiles) {\n  const crc=crc32(f.data); const loc=makeLocal(f.name,f.data);\n  locals.push(loc); cds.push(makeCD(f.name,f.data,zipOff,crc)); zipOff+=loc.length;\n}\nconst merge2 = (a,b)=>{const r=new Uint8Array(a.length+b.length);r.set(a);r.set(b,a.length);return r;};\nconst cdBuf=cds.reduce(merge2,new Uint8Array(0));\nconst eocd=makeEOCD(cdBuf.length,zipOff,zipFiles.length);\nconst localBuf=locals.reduce(merge2,new Uint8Array(0));\nconst zipFinal=merge2(merge2(localBuf,cdBuf),eocd);\nconst docxB64=Buffer.from(zipFinal).toString('base64');\n\n// ============================================================\n// 2. BUILD HTML WEBPAGE (printable, opens in browser)\n// ============================================================\nconst toHtml = txt => {\n  let out='';\n  for (const raw of txt.split('\\n')) {\n    const line=raw.trim();\n    if (!line){out+='<div style=\"height:10px\"></div>';continue;}\n    const style=detectStyle(line);\n    const clean=line.replace(/\\*\\*/g,'').replace(/</g,'&lt;').replace(/>/g,'&gt;');\n    if      (style==='h1')     out+=`<h2>${clean}</h2>`;\n    else if (style==='h2')     out+=`<h3>${clean}</h3>`;\n    else if (style==='score')  out+=`<div class=\"score\">${clean}</div>`;\n    else if (style==='bullet') out+=`<li>${clean.replace(/^[-\\u2022\\*\\d+\\.\\s]/,'')}</li>`;\n    else                       out+=`<p>${clean}</p>`;\n  }\n  return out;\n};\n\nconst htmlPage = `<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\"><title>StartIQS.AI — Idea Validation Report</title><style>*{margin:0;padding:0;box-sizing:border-box;}body{font-family:Georgia,serif;font-size:14px;color:#1a1a1a;background:#f9f9f7;}.topbar{background:#1a1a1a;color:#fff;padding:14px 40px;display:flex;align-items:center;justify-content:space-between;}.topbar .brand{font-size:16px;font-weight:bold;letter-spacing:2px;}.topbar .meta{font-size:11px;color:#aaa;}.print-btn{background:#fff;color:#1a1a1a;border:none;padding:7px 16px;font-size:12px;cursor:pointer;border-radius:3px;font-weight:bold;}.print-btn:hover{background:#eee;}.cover{background:#fff;border-bottom:3px solid #1a1a1a;padding:60px 80px 50px;text-align:center;}.cover h1{font-size:28px;font-weight:bold;letter-spacing:1px;margin-bottom:12px;}.cover .sub{font-size:14px;color:#666;margin-bottom:6px;}.cover .date{font-size:12px;color:#999;margin-top:8px;}.container{max-width:900px;margin:40px auto;padding:0 40px 80px;}h2{font-size:14px;font-weight:bold;text-transform:uppercase;letter-spacing:1px;background:#f4f4f4;border-left:5px solid #1a1a1a;padding:10px 16px;margin:40px 0 14px;}h3{font-size:13px;font-weight:bold;color:#333;margin:20px 0 8px;border-bottom:1px solid #e0e0e0;padding-bottom:4px;}p{font-size:13px;line-height:1.8;color:#333;margin-bottom:10px;text-align:justify;}li{font-size:13px;line-height:1.8;color:#444;margin:5px 0 5px 28px;}.score{font-weight:bold;color:#7a5c10;background:#fdf8ec;border:1px solid #e0c96e;padding:5px 12px;border-radius:4px;display:inline-block;margin:8px 0;font-size:13px;}.footer{text-align:center;font-size:11px;color:#aaa;padding:30px;border-top:1px solid #e0e0e0;margin-top:40px;background:#fff;}@media print{.topbar .print-btn{display:none;}body{background:#fff;}h2,.score{-webkit-print-color-adjust:exact;print-color-adjust:exact;}}@media(max-width:700px){.cover{padding:40px 20px 30px;}.container{padding:0 16px 60px;}h2,p,li{font-size:12px;}}</style></head><body><div class=\"topbar\"><div class=\"brand\">STARTIQ</div><div class=\"meta\">Idea Validation Engine · ${date}</div><button class=\"print-btn\" onclick=\"window.print()\">Print / Save PDF</button></div><div class=\"cover\"><h1>STARTUP IDEA VALIDATION REPORT</h1><div class=\"sub\">Institutional-Grade Analysis · 30 Sections</div><div class=\"date\">Generated: ${date} · Confidential</div></div><div class=\"container\">${toHtml(fullText)}</div><div class=\"footer\">StartIQ Idea Validation Engine · ${date} · Confidential</div></body></html>`;\n\nconst htmlB64=Buffer.from(htmlPage).toString('base64');\n\n// ============================================================\n// Output 2 files: DOCX + HTML\n// ============================================================\nreturn [\n  {\n    json: {report:'DOCX', filename:`StartIQ_Report_${safeDate}.docx`},\n    binary: {\n      data: {\n        data: docxB64,\n        mimeType: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',\n        fileName: `StartIQ_Report_${safeDate}.docx`,\n        fileExtension: 'docx'\n      }\n    }\n  },\n  {\n    json: {report:'HTML Webpage', filename:`StartIQ_Report_${safeDate}.html`},\n    binary: {\n      data: {\n        data: htmlB64,\n        mimeType: 'text/html',\n        fileName: `StartIQ_Report_${safeDate}.html`,\n        fileExtension: 'html'\n      }\n    }\n  }\n];"
