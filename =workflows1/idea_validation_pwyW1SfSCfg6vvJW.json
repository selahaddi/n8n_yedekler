        "jsCode": "// Get all merged items and build HTML\nconst allItems = $input.all();\n\nlet bodyContent = '';\n\nallItems.forEach((item, index) => {\n  const data = item.json;\n  \n  // Loop through each key-value in the item\n  let fields = '';\n  for (const [key, value] of Object.entries(data)) {\n    fields += `\n      <tr>\n        <td style=\"font-weight:bold; padding:8px; border:1px solid #ddd; background:#f5f5f5; width:30%\">${key}</td>\n        <td style=\"padding:8px; border:1px solid #ddd;\">${value}</td>\n      </tr>`;\n  }\n\n  bodyContent += `\n    <div style=\"margin-bottom:30px;\">\n      <h2 style=\"color:#333; border-bottom:2px solid #4CAF50; padding-bottom:5px;\">\n        Idea ${index + 1}\n      </h2>\n      <table style=\"width:100%; border-collapse:collapse;\">\n        ${fields}\n      </table>\n    </div>`;\n});\n\nconst html = `\n<html>\n  <head>\n    <style>\n      body { font-family: Arial, sans-serif; padding: 30px; color: #333; }\n      h1 { color: #2c3e50; text-align: center; }\n    </style>\n  </head>\n  <body>\n    <h1>Idea Validation Report</h1>\n    ${bodyContent}\n  </body>\n</html>`;\n\nreturn [{ json: { html } }];"
