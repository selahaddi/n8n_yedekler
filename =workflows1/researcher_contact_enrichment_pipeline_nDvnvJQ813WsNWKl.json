    },
    {
      "parameters": {
        "jsCode": "// Python script'in stdout çıktısını JSON olarak parse eder\nconst stdout = $input.item.json.stdout;\n\ntry {\n  const parsed = JSON.parse(stdout.trim());\n  return [{ json: parsed }];\n} catch (e) {\n  return [{ json: {\n    ResearcherName: 'PARSE_ERROR',\n    Institution: '',\n    LinkedIn: '',\n    Email: '',\n    Phone: '',\n    Source: 'error',\n    Status: 'error',\n    ErrorMessage: e.message,\n    RawOutput: stdout\n  }}];\n}"
      },
      "id": "ecf27453-017a-42a3-8574-7ea15f6632ba",
