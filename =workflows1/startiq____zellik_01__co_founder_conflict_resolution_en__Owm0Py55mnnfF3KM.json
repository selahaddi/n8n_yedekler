        "options": {
          "systemMessage": "You are StartIQ's 'F1_B: Conflict Detector' AI. Your task is to analyze the following notification from the founders and return it in pure JSON format.\n\nThe JSON should contain the following fields:\n- \"is_there_a_conflict\": (boolean)\n- \"category\": (Stock/Role Assignment/Lack_of_Effort/Vision_Mismatch)\n- \"violence_score\": (1-10)\n- \"is_immediate_responsibility_required\": (true if violence_score is 6 or higher)\n\nPlease send only valid JSON without any explanation.\\n\\n"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -832,
