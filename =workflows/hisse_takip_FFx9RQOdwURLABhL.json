    {
      "parameters": {
        "jsCode": "// Portföy AI Analizi için Output Parser\n// Portföy raporunu formatla\n\nconst portfolioData = $input.first().json.portfolio;\nconst allStocks = $input.first().json.allStocks;\n\n// AI'dan gelen analiz\nconst analysis = $input.all()[0].json.output || '';\n\n// Beklenen format\nconst formattedOutput = `\n📊 PORTFÖY GENEL DEĞERLENDİRMESİ\n${extractSection(analysis, 'genel', 'Portföy performansı ve genel durum')}\n\n📈 PİYASA TRENDİ ANALİZİ\n${extractSection(analysis, 'trend', 'Piyasa trendi değerlendirmesi')}\n\n🎯 ÖNE ÇIKAN HİSSELER\n${extractSection(analysis, 'öne çıkan', 'En iyi ve en kötü performans gösteren hisseler')}\n\n💡 YATIRIM ÖNERİSİ\n${extractSection(analysis, 'öneri', 'Portföy için genel öneri')}\n\n⚠️ RİSK DEĞERLENDİRMESİ\n${extractSection(analysis, 'risk', 'Portföy risk seviyesi')}\n`;\n\nfunction extractSection(text, keyword, defaultText) {\n    // Basit metin ayrıştırma\n    const lines = text.split('\\\\n');\n    let section = [];\n    let capturing = false;\n\n    for (let line of lines) {\n        const lowerLine = line.toLowerCase();\n        if (lowerLine.includes(keyword) || lowerLine.includes(defaultText.toLowerCase())) {\n            capturing = true;\n            continue;\n        }\n        if (capturing) {\n            if (line.trim() === '' || line.match(/^\\\\d+\\\\./)) {\n                break;\n            }\n            section.push(line);\n        }\n    }\n\n    return section.length > 0 ? section.join('\\\\n').trim() : defaultText;\n}\n\nreturn [{\n    json: {\n        analysis: formattedOutput,\n        portfolio: portfolioData,\n        allStocks: allStocks\n    }\n}];\n"
      },
