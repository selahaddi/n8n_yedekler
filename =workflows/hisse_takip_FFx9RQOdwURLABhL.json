      "id": "ebf86c91-73bc-45c5-8a0f-88632fea707d",
      "name": "Merge All Stocks"
    },
    {
      "parameters": {
        "jsCode": "// Portföy Analizi ve Özet Raporu\n// Gelen veri: [{ stocks: [...] }] formatında\nconst inputData = $input.first().json;\nconst allStocks = inputData.stocks || [];\n\n// Portföy istatistikleri\nlet totalChangePercent = 0;\nlet bestPerformer = null;\nlet worstPerformer = null;\nlet totalRSI = 0;\nlet rsiCount = 0;\n\nconst stockDetails = [];\n\nallStocks.forEach(stock => {\n    // stock artık doğrudan obje\n\n    // Detayları kaydet\n    stockDetails.push({\n        symbol: stock.symbol,\n        name: stock.name,\n        price: stock.priceData.currentPrice,\n        change: stock.priceData.change,\n        changePercent: parseFloat(stock.priceData.changePercent),\n        rsi: stock.technicalData?.technicalIndicators?.rsi?.value || null,\n        macd: stock.technicalData?.technicalIndicators?.macd?.signalText || 'N/A',\n        newsCount: stock.newsCount || 0\n    });\n\n    // İstatistik hesaplamaları\n    const changePercent = parseFloat(stock.priceData.changePercent);\n    totalChangePercent += changePercent;\n\n    // En iyi/kötü performans\n    if (!bestPerformer || changePercent > bestPerformer.changePercent) {\n        bestPerformer = {\n            symbol: stock.symbol,\n            name: stock.name,\n            changePercent: changePercent\n        };\n    }\n\n    if (!worstPerformer || changePercent < worstPerformer.changePercent) {\n        worstPerformer = {\n            symbol: stock.symbol,\n            name: stock.name,\n            changePercent: changePercent\n        };\n    }\n\n    // RSI ortalaması\n    if (stock.technicalData?.technicalIndicators?.rsi?.value) {\n        totalRSI += stock.technicalData.technicalIndicators.rsi.value;\n        rsiCount++;\n    }\n});\n\n// Ortalamalar\nconst avgChangePercent = totalChangePercent / allStocks.length;\nconst avgRSI = rsiCount > 0 ? totalRSI / rsiCount : null;\n\n// Piyasa trendi\nlet marketTrend = 'Yatay';\nif (avgChangePercent > 1) marketTrend = 'Yükseliş';\nelse if (avgChangePercent < -1) marketTrend = 'Düşüş';\n\n// Portföy özeti\nconst portfolioSummary = {\n    totalStocks: allStocks.length,\n    avgChangePercent: parseFloat(avgChangePercent.toFixed(2)),\n    bestPerformer: bestPerformer,\n    worstPerformer: worstPerformer,\n    avgRSI: avgRSI ? parseFloat(avgRSI.toFixed(2)) : null,\n    marketTrend: marketTrend,\n    stockDetails: stockDetails\n};\n\nreturn [{\n    json: {\n        portfolio: portfolioSummary,\n        allStocks: allStocks  // Artık doğrudan array\n    }\n}];\n"
      },
