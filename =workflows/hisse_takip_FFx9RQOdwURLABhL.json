      "id": "dbf94c59-ecc6-4e1e-85d7-e0140b2037ba",
      "name": "Historical Data",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Teknik Analiz Göstergeleri Hesaplama\nconst historicalData = $json.chart.result[0];\nconst timestamps = historicalData.timestamp;\nconst quotes = historicalData.indicators.quote[0];\nconst closePrices = quotes.close.filter(p => p !== null);\n\n// Yardımcı Fonksiyonlar\nfunction calculateEMA(prices, period) {\n  const k = 2 / (period + 1);\n  let ema = prices[0];\n  \n  for (let i = 1; i < prices.length; i++) {\n    ema = (prices[i] * k) + (ema * (1 - k));\n  }\n  \n  return ema;\n}\n\nfunction calculateSMA(prices, period) {\n  const slice = prices.slice(-period);\n  return slice.reduce((a, b) => a + b, 0) / period;\n}\n\nfunction calculateStdDev(prices, period) {\n  const slice = prices.slice(-period);\n  const mean = calculateSMA(prices, period);\n  const squareDiffs = slice.map(price => Math.pow(price - mean, 2));\n  const avgSquareDiff = squareDiffs.reduce((a, b) => a + b, 0) / period;\n  return Math.sqrt(avgSquareDiff);\n}\n\n// RSI Hesaplama (14 günlük)\nfunction calculateRSI(prices, period = 14) {\n  if (prices.length < period + 1) return null;\n  \n  let gains = 0;\n  let losses = 0;\n  \n  for (let i = prices.length - period; i < prices.length; i++) {\n    const change = prices[i] - prices[i - 1];\n    if (change > 0) gains += change;\n    else losses -= change;\n  }\n  \n  const avgGain = gains / period;\n  const avgLoss = losses / period;\n  \n  if (avgLoss === 0) return 100;\n  \n  const rs = avgGain / avgLoss;\n  const rsi = 100 - (100 / (1 + rs));\n  \n  return parseFloat(rsi.toFixed(2));\n}\n\n// MACD Hesaplama\nfunction calculateMACD(prices) {\n  if (prices.length < 26) return null;\n  \n  const ema12 = calculateEMA(prices, 12);\n  const ema26 = calculateEMA(prices, 26);\n  const macd = ema12 - ema26;\n  \n  // Signal line (9-day EMA of MACD)\n  const macdValues = [];\n  for (let i = 26; i < prices.length; i++) {\n    const slice = prices.slice(0, i + 1);\n    const e12 = calculateEMA(slice, 12);\n    const e26 = calculateEMA(slice, 26);\n    macdValues.push(e12 - e26);\n  }\n  \n  const signal = calculateEMA(macdValues, 9);\n  const histogram = macd - signal;\n  \n  return {\n    macd: parseFloat(macd.toFixed(2)),\n    signal: parseFloat(signal.toFixed(2)),\n    histogram: parseFloat(histogram.toFixed(2))\n  };\n}\n\n// Bollinger Bands Hesaplama\nfunction calculateBollingerBands(prices, period = 20, stdDevMultiplier = 2) {\n  if (prices.length < period) return null;\n  \n  const sma = calculateSMA(prices, period);\n  const stdDev = calculateStdDev(prices, period);\n  \n  return {\n    upper: parseFloat((sma + (stdDev * stdDevMultiplier)).toFixed(2)),\n    middle: parseFloat(sma.toFixed(2)),\n    lower: parseFloat((sma - (stdDev * stdDevMultiplier)).toFixed(2))\n  };\n}\n\n// Göstergeleri Hesapla\nconst rsi = calculateRSI(closePrices);\nconst macd = calculateMACD(closePrices);\nconst bollinger = calculateBollingerBands(closePrices);\n\n// RSI Sinyali\nlet rsiSignal = 'Nötr';\nlet rsiClass = 'neutral';\nif (rsi !== null) {\n  if (rsi > 70) {\n    rsiSignal = 'Aşırı Alım';\n    rsiClass = 'overbought';\n  } else if (rsi < 30) {\n    rsiSignal = 'Aşırı Satım';\n    rsiClass = 'oversold';\n  }\n}\n\n// MACD Sinyali\nlet macdSignal = 'Nötr';\nif (macd !== null) {\n  if (macd.histogram > 0) {\n    macdSignal = 'Alım Sinyali';\n  } else if (macd.histogram < 0) {\n    macdSignal = 'Satım Sinyali';\n  }\n}\n\n// Bollinger Sinyali\nlet bollingerSignal = 'Nötr';\nconst currentPrice = closePrices[closePrices.length - 1];\nif (bollinger !== null) {\n  if (currentPrice > bollinger.upper) {\n    bollingerSignal = 'Üst Banda Yakın (Aşırı Alım)';\n  } else if (currentPrice < bollinger.lower) {\n    bollingerSignal = 'Alt Banda Yakın (Aşırı Satım)';\n  }\n}\n\nreturn [{\n  json: {\n    symbol: $json.chart.result[0].meta.symbol.replace('.IS', ''),\n    technicalIndicators: {\n      rsi: {\n        value: rsi,\n        signal: rsiSignal,\n        class: rsiClass\n      },\n      macd: {\n        value: macd?.macd || null,\n        signal: macd?.signal || null,\n        histogram: macd?.histogram || null,\n        signalText: macdSignal\n      },\n      bollinger: {\n        upper: bollinger?.upper || null,\n        middle: bollinger?.middle || null,\n        lower: bollinger?.lower || null,\n        signal: bollingerSignal\n      }\n    },\n    historicalPrices: closePrices.slice(-30), // Son 30 gün\n    timestamps: timestamps.slice(-30).map(t => new Date(t * 1000).toLocaleDateString('tr-TR'))\n  }\n}];\n"
      },
