    {
      "parameters": {
        "jsCode": "// QuickChart ile Fiyat Grafiği Oluşturma\nconst technicalData = $json.technicalIndicators;\nconst prices = $json.historicalPrices;\nconst labels = $json.timestamps;\nconst bollinger = technicalData.bollinger;\n\nconst chartConfig = {\n    type: 'line',\n    data: {\n        labels: labels,\n        datasets: [\n            {\n                label: 'Fiyat',\n                data: prices,\n                borderColor: '#667eea',\n                backgroundColor: 'rgba(102, 126, 234, 0.1)',\n                borderWidth: 3,\n                fill: true,\n                tension: 0.4\n            },\n            {\n                label: 'Bollinger Üst',\n                data: Array(prices.length).fill(bollinger.upper),\n                borderColor: '#ef4444',\n                borderWidth: 2,\n                borderDash: [5, 5],\n                fill: false,\n                pointRadius: 0\n            },\n            {\n                label: 'Bollinger Orta',\n                data: Array(prices.length).fill(bollinger.middle),\n                borderColor: '#6b7280',\n                borderWidth: 1,\n                borderDash: [2, 2],\n                fill: false,\n                pointRadius: 0\n            },\n            {\n                label: 'Bollinger Alt',\n                data: Array(prices.length).fill(bollinger.lower),\n                borderColor: '#10b981',\n                borderWidth: 2,\n                borderDash: [5, 5],\n                fill: false,\n                pointRadius: 0\n            }\n        ]\n    },\n    options: {\n        responsive: true,\n        plugins: {\n            title: {\n                display: true,\n                text: `${$json.symbol} - Son 30 Gün Fiyat Grafiği`,\n                font: { size: 16, weight: 'bold' }\n            },\n            legend: {\n                display: true,\n                position: 'bottom'\n            }\n        },\n        scales: {\n            y: {\n                beginAtZero: false,\n                ticks: {\n                    callback: function (value) {\n                        return value.toFixed(2) + ' TL';\n                    }\n                }\n            }\n        }\n    }\n};\n\nconst chartUrl = `https://quickchart.io/chart?c=${encodeURIComponent(JSON.stringify(chartConfig))}&width=600&height=300&backgroundColor=white`;\n\nreturn [{\n    json: {\n        ...$json,\n        chartUrl: chartUrl\n    }\n}];\n"
      },
