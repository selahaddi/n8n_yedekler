    {
      "parameters": {
        "jsCode": "// Teknik analiz verilerini al\nconst technicalData = $('GENARETE CHART').first()?.json;\nconst hasTA = technicalData && technicalData.technicalIndicators;\nconst priceItem = $('Format Price Data5').first();\nconst priceData = priceItem ? priceItem.json : null;\n\n// Loop'tan hisse bilgilerini al\nconst loopItem = $('Loop Over Items').item.json;\nconst stockSymbol = loopItem.symbol;\nconst stockName = loopItem.name;\n\nif (!priceData) {\n    return [{ json: { error: 'Fiyat verisi alınamadı' } }];\n}\n\nconst newsItems = $input.all().filter(item => !item.json.noNews);\n\nconst changeEmoji = priceData.changePercent > 0 ? '📈' :\n    priceData.changePercent < 0 ? '📉' : '➡️';\n\nlet report = `🏢 *${stockName} (${stockSymbol}) RAPORU*\\\\n`;\nreport += `📅 ${priceData.timestamp}\\\\n\\\\n`;\n\nreport += `💰 *FİYAT BİLGİLERİ*\\\\n`;\n// Teknik Analiz Bölümü\nif (hasTA) {\n    const ta = technicalData.technicalIndicators;\n\n    report += `\\\\n📊 *TEKNİK ANALİZ*\\\\n`;\n    report += `━━━━━━━━━━━━━━━━━━\\\\n`;\n\n    // RSI\n    if (ta.rsi.value !== null) {\n        const rsiEmoji = ta.rsi.class === 'overbought' ? '🔴' :\n            ta.rsi.class === 'oversold' ? '🟢' : '🟡';\n        report += `${rsiEmoji} RSI (14): *${ta.rsi.value}* - ${ta.rsi.signal}\\\\n`;\n    }\n\n    // MACD\n    if (ta.macd.value !== null) {\n        const macdEmoji = ta.macd.histogram > 0 ? '📈' : '📉';\n        report += `${macdEmoji} MACD: ${ta.macd.value} (Sinyal: ${ta.macd.signal})\\\\n`;\n        report += `   Histogram: ${ta.macd.histogram} - ${ta.macd.signalText}\\\\n`;\n    }\n\n    // Bollinger Bands\n    if (ta.bollinger.upper !== null) {\n        report += `📊 Bollinger Bands:\\\\n`;\n        report += `   Üst: ${ta.bollinger.upper} TL\\\\n`;\n        report += `   Orta: ${ta.bollinger.middle} TL\\\\n`;\n        report += `   Alt: ${ta.bollinger.lower} TL\\\\n`;\n        report += `   Durum: ${ta.bollinger.signal}\\\\n`;\n    }\n\n    report += `\\\\n`;\n}\n\nreport += `━━━━━━━━━━━━━━━━━━\\\\n`;\nreport += `Güncel Fiyat: *${priceData.currentPrice.toFixed(2)} TL*\\\\n`;\nreport += `Önceki Kapanış: ${priceData.previousClose.toFixed(2)} TL\\\\n`;\nreport += `Değişim: ${priceData.change.toFixed(2)} TL (${changeEmoji} *%${priceData.changePercent}*)\\\\n`;\nreport += `Gün En Yüksek: ${priceData.dayHigh.toFixed(2)} TL\\\\n`;\nreport += `Gün En Düşük: ${priceData.dayLow.toFixed(2)} TL\\\\n`;\nreport += `Hacim: ${(priceData.volume / 1000000).toFixed(2)}M\\\\n\\\\n`;\n\nreport += `📰 *SON HABERLER*\\\\n`;\nreport += `━━━━━━━━━━━━━━━━━━\\\\n`;\n\nif (newsItems.length > 0) {\n    newsItems.forEach((item, index) => {\n        const news = item.json;\n        const date = new Date(news.publishedAt);\n        const formattedDate = date.toLocaleString('tr-TR', {\n            day: '2-digit',\n            month: '2-digit',\n            hour: '2-digit',\n            minute: '2-digit'\n        });\n\n        report += `\\\\n${index + 1}. ${news.sentiment} *${news.title}*\\\\n`;\n        if (news.description) {\n            const shortDesc = news.description.substring(0, 120);\n            report += `   ${shortDesc}${news.description.length > 120 ? '...' : ''}\\\\n`;\n        }\n        report += `   📍 ${news.source} | ⏰ ${formattedDate}\\\\n`;\n        report += `   🔗 ${news.url}\\\\n`;\n    });\n} else {\n    report += `\\\\n⚠️ Son 24 saatte ${stockName} ile ilgili önemli haber bulunmamaktadır.\\\\n`;\n}\n\nreport += `\\\\n━━━━━━━━━━━━━━━━━━\\\\n`;\nreport += `🤖 N8N Otomatik Rapor Sistemi`;\n\nconst hasSignificantChange = Math.abs(parseFloat(priceData.changePercent)) > 2;\nconst hasNegativeNews = newsItems.some(item => item.json.sentimentScore < -1);\nconst hasPositiveNews = newsItems.some(item => item.json.sentimentScore > 1);\n\nreturn [{\n    json: {\n        symbol: stockSymbol,  // YENİ: Hisse sembolü\n        name: stockName,      // YENİ: Hisse adı\n        report: report,\n        priceData: priceData,\n        newsCount: newsItems.length,\n        hasSignificantChange: hasSignificantChange,\n        hasNegativeNews: hasNegativeNews,\n        hasPositiveNews: hasPositiveNews,\n        shouldAlert: hasSignificantChange || hasNegativeNews || hasPositiveNews,\n        technicalData: technicalData\n    }\n}];\n"
      },
