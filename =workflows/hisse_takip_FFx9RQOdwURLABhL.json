        864,
        480
      ],
      "id": "492f3b54-f8e6-4f08-aca0-06ddc21300b0"
    },
    {
      "parameters": {
        "jsCode": "const keywords = {\n  positive: ['yükseliş', 'yükseldi', 'artış', 'arttı', 'kâr', 'kar', 'başarı', 'rekor', 'büyüme', 'büyüdü', 'güçlendi', 'olumlu', 'pozitif'],\n  negative: ['düşüş', 'düştü', 'azaldı', 'azalış', 'zarar', 'kriz', 'sorun', 'kayıp', 'kaybetti', 'olumsuz', 'negatif', 'risk'],\n  neutral: ['açıklama', 'duyuru', 'bilgi', 'toplantı', 'planlıyor', 'değerlendirme']\n};\n\nconst articles = $input.all();\nconst filteredNews = [];\n\nfor (let item of articles) {\n  if (!item.json.articles) continue;\n  \n  for (let article of item.json.articles) {\n    const title = (article.title || '').toLowerCase();\n    const description = (article.description || '').toLowerCase();\n    const content = title + ' ' + description;\n    \n    // THY ile ilgili mi kontrol et\n    const isRelevant = content.includes('thy') || \n                      content.includes('türk hava') || \n                      content.includes('turkish airlines') || \n                      content.includes('thyao');\n    \n    if (!isRelevant) continue;\n    \n    // Sentiment analizi\n    let sentiment = 0;\n    keywords.positive.forEach(word => {\n      const count = (content.match(new RegExp(word, 'g')) || []).length;\n      sentiment += count;\n    });\n    keywords.negative.forEach(word => {\n      const count = (content.match(new RegExp(word, 'g')) || []).length;\n      sentiment -= count;\n    });\n    \n    let sentimentLabel = '🟡 Nötr';\n    if (sentiment > 0) sentimentLabel = '🟢 Pozitif';\n    if (sentiment < 0) sentimentLabel = '🔴 Negatif';\n    \n    filteredNews.push({\n      json: {\n        title: article.title,\n        description: article.description,\n        url: article.url,\n        source: article.source?.name || 'Bilinmeyen',\n        publishedAt: article.publishedAt,\n        sentiment: sentimentLabel,\n        sentimentScore: sentiment\n      }\n    });\n  }\n}\n\n// En yeni ve en önemli 5 haberi al\nconst sortedNews = filteredNews\n  .sort((a, b) => {\n    const dateCompare = new Date(b.json.publishedAt) - new Date(a.json.publishedAt);\n    if (dateCompare !== 0) return dateCompare;\n    return Math.abs(b.json.sentimentScore) - Math.abs(a.json.sentimentScore);\n  })\n  .slice(0, 5);\n\nreturn sortedNews.length > 0 ? sortedNews : [{ json: { noNews: true } }];"
      },
