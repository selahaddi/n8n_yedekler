    {
      "parameters": {
        "jsCode": "// Portföy HTML Email Template\n// Portfolio Analysis node'undan veriyi al\nconst portfolioData = $('Portfolio Analysis').first().json;\nconst portfolio = portfolioData.portfolio;\nconst allStocks = portfolioData.allStocks;\n\n// AI analizini al (Portfolio AI Agent'tan gelecek)\nlet aiAnalysis = $('Portfolio AI Agent').first()?.json?.output || '';\n\n// Undefined ve null değerleri temizle\nif (aiAnalysis) {\n  aiAnalysis = aiAnalysis\n    .replace(/undefined/g, '')\n    .replace(/null/g, '')\n    .replace(/\\s+/g, ' ')  // Çoklu boşlukları tek boşluğa indir\n    .trim();\n}\n\n// Undefined ve null değerleri temizle\nif (aiAnalysis) {\n  aiAnalysis = aiAnalysis\n    .replace(/undefined/g, '')\n    .replace(/null/g, '')\n    .replace(/\\s+/g, ' ')  // Çoklu boşlukları tek boşluğa indir\n    .trim();\n}\n\nconst changeColor = portfolio.avgChangePercent > 0 ? '#10b981' : portfolio.avgChangePercent < 0 ? '#ef4444' : '#6b7280';\nconst changeIcon = portfolio.avgChangePercent > 0 ? '📈' : portfolio.avgChangePercent < 0 ? '📉' : '➡️';\n\n// Trend emoji\nconst trendEmoji = portfolio.marketTrend === 'Yükseliş' ? '🚀' :\n  portfolio.marketTrend === 'Düşüş' ? '📉' : '➡️';\n\nconst html = `\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <style>\n    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f3f4f6; margin: 0; padding: 20px; }\n    .container { max-width: 800px; margin: 0 auto; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }\n    .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; text-align: center; }\n    .header h1 { margin: 0; font-size: 28px; }\n    .header p { margin: 10px 0 0 0; opacity: 0.9; }\n    .content { padding: 30px; }\n    \n    .portfolio-summary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 25px; border-radius: 10px; margin-bottom: 25px; }\n    .summary-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-top: 15px; }\n    .summary-item { text-align: center; }\n    .summary-label { font-size: 12px; opacity: 0.9; margin-bottom: 5px; }\n    .summary-value { font-size: 24px; font-weight: bold; }\n    \n    .stock-table { width: 100%; border-collapse: collapse; margin: 20px 0; }\n    .stock-table th { background: #f9fafb; padding: 12px; text-align: left; font-size: 12px; color: #6b7280; text-transform: uppercase; border-bottom: 2px solid #e5e7eb; }\n    .stock-table td { padding: 12px; border-bottom: 1px solid #e5e7eb; }\n    .stock-name { font-weight: bold; color: #1f2937; }\n    .stock-symbol { font-size: 12px; color: #6b7280; }\n    .positive { color: #10b981; }\n    .negative { color: #ef4444; }\n    .neutral { color: #6b7280; }\n    \n    .ai-section { background: #fef3c7; border-left: 4px solid #f59e0b; padding: 20px; border-radius: 8px; margin: 25px 0; }\n    .ai-section h3 { margin: 0 0 15px 0; color: #92400e; }\n    .ai-content { color: #78350f; line-height: 1.6; white-space: pre-wrap; }\n    \n    .accordion { margin: 10px 0; }\n    .accordion-header { background: #f9fafb; padding: 12px; cursor: pointer; border-radius: 6px; transition: background 0.2s; display: flex; justify-content: space-between; align-items: center; }\n    .accordion-header:hover { background: #f3f4f6; }\n    .accordion-icon { transition: transform 0.3s; font-size: 12px; color: #6b7280; }\n    .accordion-icon.active { transform: rotate(180deg); }\n    .accordion-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; }\n    .accordion-content.active { max-height: 500px; padding: 15px 0; }\n    .chart-image { width: 100%; border-radius: 8px; margin-top: 10px; }\n    \n    .footer { background: #f9fafb; padding: 20px; text-align: center; color: #6b7280; font-size: 12px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>💼 Portföy Raporu</h1>\n      <p>${new Date().toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</p>\n    </div>\n    \n    <div class=\"content\">\n      <div class=\"portfolio-summary\">\n        <h2 style=\"margin: 0 0 15px 0;\">📊 Portföy Özeti</h2>\n        <div class=\"summary-grid\">\n          <div class=\"summary-item\">\n            <div class=\"summary-label\">Ortalama Değişim</div>\n            <div class=\"summary-value\">${changeIcon} ${portfolio.avgChangePercent}%</div>\n          </div>\n          <div class=\"summary-item\">\n            <div class=\"summary-label\">Piyasa Trendi</div>\n            <div class=\"summary-value\">${trendEmoji} ${portfolio.marketTrend}</div>\n          </div>\n          <div class=\"summary-item\">\n            <div class=\"summary-label\">Ortalama RSI</div>\n            <div class=\"summary-value\">${portfolio.avgRSI || 'N/A'}</div>\n          </div>\n        </div>\n        <div style=\"margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.2);\">\n          <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 15px;\">\n            <div>\n              <div class=\"summary-label\">🏆 En İyi Performans</div>\n              <div style=\"font-size: 16px; font-weight: bold; margin-top: 5px;\">\n                ${portfolio.bestPerformer.symbol} (+${portfolio.bestPerformer.changePercent}%)\n              </div>\n            </div>\n            <div>\n              <div class=\"summary-label\">📉 En Kötü Performans</div>\n              <div style=\"font-size: 16px; font-weight: bold; margin-top: 5px;\">\n                ${portfolio.worstPerformer.symbol} (${portfolio.worstPerformer.changePercent}%)\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n      \n      \n      ${aiAnalysis ? `\n      <div style=\"margin: 25px 0;\">\n        <h3 style=\"color: #1f2937; margin-bottom: 15px;\">🤖 AI Portföy Analizi</h3>\n        ${aiAnalysis}\n      </div>\n      ` : ''}\n      \n      <h3 style=\"color: #1f2937; margin-bottom: 15px;\">📈 Hisse Detayları</h3>\n      ${portfolio.stockDetails.map((stock, index) => {\n  const changeClass = stock.changePercent > 0 ? 'positive' : stock.changePercent < 0 ? 'negative' : 'neutral';\n  const changeIcon = stock.changePercent > 0 ? '▲' : stock.changePercent < 0 ? '▼' : '●';\n\n  // İlgili hissenin grafiğini allStocks'tan bul\n  const stockData = allStocks.find(s => s.symbol === stock.symbol);\n  const chartUrl = stockData?.technicalData?.chartUrl || '';\n\n  return `\n      <div style=\"background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 20px; margin-bottom: 20px;\">\n        <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; flex-wrap: wrap; gap: 10px;\">\n          <div style=\"flex: 1; min-width: 150px;\">\n            <div class=\"stock-name\">${stock.symbol}</div>\n            <div class=\"stock-symbol\">${stock.name}</div>\n          </div>\n          <div style=\"min-width: 100px; text-align: right;\">\n            <div style=\"font-size: 18px; font-weight: bold;\">${stock.price.toFixed(2)} TL</div>\n            <div class=\"${changeClass}\" style=\"font-size: 14px;\">${changeIcon} ${stock.changePercent}%</div>\n          </div>\n        </div>\n        \n        <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 10px; margin-bottom: 15px; padding: 15px; background: #f9fafb; border-radius: 6px;\">\n          <div>\n            <div style=\"font-size: 11px; color: #6b7280; margin-bottom: 3px;\">RSI</div>\n            <div style=\"font-weight: bold;\">${stock.rsi || 'N/A'}</div>\n          </div>\n          <div>\n            <div style=\"font-size: 11px; color: #6b7280; margin-bottom: 3px;\">MACD</div>\n            <div style=\"font-weight: bold;\">${stock.macd}</div>\n          </div>\n          <div>\n            <div style=\"font-size: 11px; color: #6b7280; margin-bottom: 3px;\">Haberler</div>\n            <div style=\"font-weight: bold;\">${stock.newsCount} haber</div>\n          </div>\n        </div>\n        \n        ${chartUrl ? `\n        <div style=\"margin-top: 15px;\">\n          <div style=\"font-size: 12px; color: #6b7280; margin-bottom: 10px;\">📊 Son 30 Gün Fiyat Grafiği</div>\n          <img src=\"${chartUrl}\" alt=\"${stock.symbol} Grafiği\" style=\"width: 100%; border-radius: 8px;\">\n        </div>\n        ` : ''}\n      </div>\n            `;\n}).join('')}\n    </div>\n    \n    <div class=\"footer\">\n      <p>🤖 N8N Otomatik Portföy Rapor Sistemi</p>\n      <p>Bu rapor ${portfolio.totalStocks} hisse senedi için otomatik olarak oluşturulmuştur.</p>\n    </div>\n  </div>\n</body>\n</html>\n`;\n\nreturn [{\n  json: {\n    html: html,\n    subject: `💼 Portföy Raporu - ${changeIcon} ${portfolio.avgChangePercent}% (${portfolio.marketTrend})`,\n    portfolio: portfolio\n  }\n}];\n"
      },
