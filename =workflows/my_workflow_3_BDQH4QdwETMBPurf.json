    {
      "parameters": {
        "jsCode": "// AI Agent'tan gelen karmaşık yapıyı (output.haberler) düz listeye çevirir\nconst results = [];\nfor (const item of $input.all()) {\n  if (item.json.output && item.json.output.haberler) {\n    for (const haber of item.json.output.haberler) {\n      results.push({ json: haber });\n    }\n  }\n}\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2032,
        688
      ],
      "id": "a65a0550-c0ea-4b68-a1f1-6239935d6bbd",
      "name": "Code in JavaScript12"
    },
    {
      "parameters": {
        "jsCode": "// Gelen tüm haberleri tek bir HTML gövdesinde birleştiriyoruz\nlet htmlBody = `\n<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: auto; border: 1px solid #eee; padding: 20px;\">\n  <h2 style=\"color: #2c3e50; text-align: center; border-bottom: 2px solid #3498db; padding-bottom: 10px;\">\n    🚀 Haftalık ASTO-Bilim Raporu - ${new Date().toLocaleDateString('tr-TR')}\n  </h2>\n`;\n\nfor (const item of $input.all()) {\n  htmlBody += `\n    <div style=\"margin-bottom: 25px; padding: 15px; background-color: #f9f9f9; border-left: 5px solid #3498db;\">\n      <h3 style=\"margin-top: 0; color: #333;\">${item.json.baslik}</h3>\n      <p style=\"color: #666; font-size: 14px; line-height: 1.6;\">${item.json.ozet}</p>\n      <div style=\"margin-top: 10px;\">\n        <span style=\"background: #e1f5fe; color: #01579b; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold;\">\n          ${item.json.kategori}\n        </span>\n        <span style=\"margin-left: 10px; color: #e67e22; font-weight: bold; font-size: 12px;\">\n          Önem: ${item.json.onem_skoru}\n        </span>\n      </div>\n      <a href=\"${item.json.url}\" style=\"display: inline-block; margin-top: 12px; color: #3498db; text-decoration: none; font-weight: bold;\">\n        Haberin Tamamı →\n      </a>\n    </div>\n  `;\n}\n\nhtmlBody += `\n  <p style=\"text-align: center; color: #bdc3c7; font-size: 12px;\">\n    Bu e-posta n8n otomasyonu ile otomatik olarak oluşturulmuştur.\n  </p>\n</div>\n`;\n\nreturn { html: htmlBody };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1824,
        368
      ],
      "id": "f8e71b83-2ca0-4896-9550-17a8301a63e0",
      "name": "Code in JavaScript13"
    },
    {
      "parameters": {
        "jsCode": "// Gelen tüm verileri alıyoruz\nconst items = $input.all().map(item => item.json);\n\n// Puanları standardize eden (normalleştiren) fonksiyon\nfunction normalizeScore(scoreRaw) {\n  if (scoreRaw === undefined || scoreRaw === null) return 0;\n  \n  const str = String(scoreRaw).toLowerCase().trim();\n  \n  // Eğer zaten bir sayıysa direkt sayıya çevir\n  if (!isNaN(str) && str !== \"\") return parseFloat(str);\n  \n  // Metin bazlı puanları sayıya dönüştür\n  if (str.includes(\"yüksek\") || str.includes(\"high\") || str.includes(\"kritik\")) return 9;\n  if (str.includes(\"orta\") || str.includes(\"medium\")) return 5;\n  if (str.includes(\"düşük\") || str.includes(\"low\")) return 2;\n  \n  return 0; // Tanımlanamayanlar en sona\n}\n\n// Büyükten küçüğe sıralama (En yüksek puanlı haber en üstte)\nitems.sort((a, b) => {\n  // Not: 'onem_skoru' veya 'importance_score' alanına göre sıralar\n  const scoreA = normalizeScore(a.onem_skoru || a.importance_score);\n  const scoreB = normalizeScore(b.onem_skoru || b.importance_score);\n  \n  return scoreB - scoreA;\n});\n\n// Veriyi n8n formatında geri döndür\nreturn items.map(item => ({ json: item }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1408,
        368
      ],
      "id": "5131e4ff-4173-4b10-9ac0-d6d71f2b356a",
