    {
      "parameters": {
        "jsCode": "// AI Agent'dan gelen yapılandırılmış cevabı işle\nconst items = [];\n\nfor (const item of $input.all()) {\n  try {\n    // Structured Output Parser sayesinde veri zaten JSON objesi olarak gelir\n    const data = item.json.output || item.json;\n    \n    // Eğer 'urunler' array'i varsa (Structured Parser çıktısı)\n    if (data.urunler && Array.isArray(data.urunler)) {\n      for (const product of data.urunler) {\n        items.push({ json: product });\n      }\n    }\n    // Eğer doğrudan array ise\n    else if (Array.isArray(data)) {\n      for (const product of data) {\n        items.push({ json: product });\n      }\n    }\n    // Eğer tekil bir ürün objesi ise\n    else if (data.urun_kodu) {\n      items.push({ json: data });\n    }\n    // Fallback: string ise parse et\n    else {\n      let content = typeof data === 'string' ? data : JSON.stringify(data);\n      content = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n      const jsonMatch = content.match(/\\[\\s*\\{[\\s\\S]*\\}\\s*\\]/);\n      if (jsonMatch) content = jsonMatch[0];\n      const parsed = JSON.parse(content);\n      if (Array.isArray(parsed)) {\n        for (const p of parsed) items.push({ json: p });\n      } else {\n        items.push({ json: parsed });\n      }\n    }\n  } catch (error) {\n    items.push({\n      json: {\n        hata: 'JSON parse hatasi',\n        ham_cevap: JSON.stringify(item.json).substring(0, 500),\n        hata_detay: error.message\n      }\n    });\n  }\n}\n\nreturn items;"
      },
