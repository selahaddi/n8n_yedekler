        "jsCode": "// HTTP Request nodundan gelen ilk veriyi alıyoruz\nconst inputData = $input.first().json.data;\nconst specs = inputData.specs;\n\n// Supabase veya başka bir DB'ye aktarmak için veriyi düzleştiriyoruz (Flatten)\nconst formattedData = {\n  cihaz_adi: inputData.title,\n  kaynak_url: inputData.url,\n  islemci: specs?.Platform?.Chipset || \"Belirtilmemiş\",\n  ram_ve_depolama: specs?.Memory?.Internal || \"Belirtilmemiş\",\n  batarya: specs?.Battery?.Type || \"Belirtilmemiş\",\n  ekran_boyutu: specs?.Display?.Size || \"Belirtilmemiş\",\n  ekran_cozunurlugu: specs?.Display?.Resolution || \"Belirtilmemiş\",\n  yayinlanma_tarihi: specs?.Launch?.Announced || \"Belirtilmemiş\",\n  fiyat: specs?.Misc?.Price || \"Belirtilmemiş\",\n  \n  // Eğer ileride RAG sistemleri veya detaylı aramalar için tüm verilere \n  // ihtiyaç duyarsan diye, ham datayı da tek bir JSON objesi olarak saklıyoruz.\n  ham_detaylar: specs \n};\n\nreturn formattedData;"
