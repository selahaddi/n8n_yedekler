      {
        "parameters": {
          "jsCode": "const TECH_COMPANIES = [\n  // Büyük şirketler\n  \"apple\", \"google\", \"microsoft\", \"meta\", \"amazon\", \"tesla\",\n  \"samsung\", \"intel\", \"amd\", \"qualcomm\", \"arm\", \"tsmc\",\n  \"ibm\", \"oracle\", \"salesforce\", \"sap\", \"palantir\",\n  // Girişimler & trend\n  \"startup\", \"vc funding\", \"series a\", \"series b\", \"ipo\",\n  \"silicon valley\", \"y combinator\", \"a16z\", \"sequoia\",\n  // Ürün kategorileri\n  \"iphone\", \"android\", \"cloud computing\", \"saas\", \"api\",\n  \"cybersecurity\", \"data center\", \"semiconductor\", \"chip\",\n];\n\nreturn $input.all().map(item => {\n  // Eğer zaten AI kategorisindeyse, çift tagleme yapabiliriz\n  const text = [item.json.title || \"\", item.json.description || \"\"]\n    .join(\" \").toLowerCase();\n\n  const matched = TECH_COMPANIES.filter(k => text.includes(k));\n  if (matched.length === 0) return null;\n\n  return {\n    json: {\n      ...item.json,\n      // Zaten kategori varsa üzerine yazma\n      kategori: item.json.kategori || \"Teknoloji Şirketi\",\n      sirket_eslesmesi: matched.slice(0, 3).join(\", \"),\n    }\n  };\n}).filter(Boolean);"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1216,
          -384
        ],
        "id": "9499e72d-0d43-4531-a86f-98c20e262642",
        "name": "Teknoloji Şirketleri Kategorisi"
      },
      {
        "parameters": {
          "jsCode": "const AI_KEYWORDS = [\n  // Modeller & Şirketler\n  \"openai\", \"anthropic\", \"google deepmind\", \"mistral\", \"llama\", \"gpt\",\n  \"gemini\", \"claude\", \"chatgpt\", \"copilot\",\n  // Teknik terimler\n  \"large language model\", \"llm\", \"neural network\", \"deep learning\",\n  \"machine learning\", \"generative ai\", \"diffusion model\", \"transformer\",\n  \"reinforcement learning\", \"rlhf\", \"fine-tuning\", \"embedding\",\n  // Ürün & uygulama\n  \"ai agent\", \"ai tool\", \"ai assistant\", \"ai model\", \"ai chip\",\n  \"gpu\", \"tpu\", \"nvidia\", \"inference\", \"training run\",\n];\n\nreturn $input.all().map(item => {\n  const text = [item.json.title || \"\", item.json.description || \"\"]\n    .join(\" \").toLowerCase();\n\n  const matchCount = AI_KEYWORDS.filter(k => text.includes(k)).length;\n\n  // En az 1 eşleşme şart; 2+ ise kategoriyi ata\n  if (matchCount === 0) return null;\n\n  return {\n    json: {\n      ...item.json,\n      kategori: \"Yapay Zeka\",\n      ai_skor: matchCount,\n    }\n  };\n}).filter(Boolean);"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1040,
          -384
        ],
        "id": "60a7edf4-3003-4f4d-ae43-169d15c725a0",
        "name": "Yapay Zeka Kategorisi"
      },
      {
        "parameters": {
          "jsCode": "const BLACKLIST = [\n  // Kripto & finans spekülatif\n  \"bitcoin\", \"crypto\", \"cryptocurrency\", \"nft\", \"blockchain\", \"ethereum\",\n  \"dogecoin\", \"binance\", \"coinbase\", \"altcoin\", \"defi\", \"web3\",\n  // Oyun & eğlence\n  \"gaming\", \"video game\", \"esports\", \"xbox\", \"playstation\", \"nintendo\",\n  \"fortnite\", \"minecraft\", \"twitch\", \"streaming\",\n  // Magazin & tıkbait\n  \"celebrity\", \"kardashian\", \"gossip\", \"leaked\", \"viral dance\",\n  // Spor (teknoloji ile ilgisi yoksa)\n  \"nfl\", \"nba\", \"soccer\", \"football score\",\n];\n\nreturn $input.all().filter(item => {\n  const text = [\n    item.json.title || \"\",\n    item.json.description || \"\",\n    item.json.source_name || \"\"\n  ].join(\" \").toLowerCase();\n\n  return !BLACKLIST.some(word => text.includes(word));\n});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          832,
          -384
        ],
        "id": "e02061e7-d11a-4fad-bf87-ce1069addd9a",
        "name": "Kara Liste Filtresi"
      },
      {
        "parameters": {
          "jsCode": "return $input.all().filter(item => {\n  const title = item.json.title || \"\";\n  const desc  = item.json.description || \"\";\n\n  // Başlık en az 10 karakter olmalı\n  if (title.length < 10) return false;\n\n  // \"[Removed]\" gibi silinmiş haberler\n  if (title.includes(\"[Removed]\") || title === \"null\") return false;\n\n  // Açıklama tamamen boşsa atla\n  if (desc.trim().length === 0) return false;\n\n  // Türkçe/Arapça/Çince karakter ağırlıklıysa atla (opsiyonel)\n  const nonLatinRatio = (title.match(/[^\\x00-\\x7F]/g) || []).length / title.length;\n  if (nonLatinRatio > 0.4) return false;\n\n  return true;\n});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          624,
          -384
        ],
        "id": "a38216a9-1ebf-4ef2-8f20-77df693e15e4",
        "name": "Dil & Kalite Filtresi"
      },
      {
        "parameters": {
          "jsCode": "const SECTORS = {\n  \"Sağlık Teknolojisi\": [\n    \"healthtech\", \"medtech\", \"clinical ai\", \"drug discovery\", \"radiology ai\",\n    \"medical imaging\", \"hospital\", \"fda approval\", \"biotech\", \"genomics\",\n    \"mental health app\", \"wearable health\"\n  ],\n  \"Siber Güvenlik\": [\n    \"cybersecurity\", \"ransomware\", \"data breach\", \"hacking\", \"malware\",\n    \"zero-day\", \"phishing\", \"vulnerability\", \"cve\", \"security flaw\",\n    \"encryption\", \"firewall\"\n  ],\n  \"Fintech\": [\n    \"fintech\", \"digital banking\", \"payment\", \"neobank\", \"insurtech\",\n    \"regtech\", \"open banking\", \"central bank digital\", \"cbdc\",\n    \"fraud detection ai\"\n  ],\n  \"Yeşil Teknoloji\": [\n    \"green tech\", \"cleantech\", \"renewable energy\", \"solar panel\",\n    \"electric vehicle\", \"ev battery\", \"carbon capture\", \"climate ai\",\n    \"energy efficiency\", \"smart grid\"\n  ],\n};\n\nreturn $input.all().map(item => {\n  const text = [item.json.title || \"\", item.json.description || \"\"]\n    .join(\" \").toLowerCase();\n\n  for (const [sektor, keywords] of Object.entries(SECTORS)) {\n    if (keywords.some(k => text.includes(k))) {\n      return {\n        json: {\n          ...item.json,\n          kategori: item.json.kategori || sektor,\n          sektor_etiketi: sektor,\n        }\n      };\n    }\n  }\n\n  // Hiçbir sektöre uymuyorsa \"Genel Teknoloji\" olarak devam et\n  return {\n    json: {\n      ...item.json,\n      kategori: item.json.kategori || \"Genel Teknoloji\",\n    }\n  };\n});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1424,
          -384
        ],
        "id": "a8aff066-e789-4f91-a22b-435115b42478",
        "name": "Sektör Haberleri Filtresi"
      },
      {
        "parameters": {
          "jsCode": "const seenUrls   = new Set();\nconst seenTitles = new Set();\n\n// Başlığı normalize et: küçük harf, noktalama kaldır, kıs\nfunction normalizeTitle(title) {\n  return title\n    .toLowerCase()\n    .replace(/[^a-z0-9 ]/g, \"\")\n    .split(\" \")\n    .slice(0, 6)   // İlk 6 kelime yeterli\n    .join(\" \");\n}\n\nreturn $input.all().filter(item => {\n  const url   = (item.json.url || \"\").split(\"?\")[0]; // Query string olmadan\n  const title = normalizeTitle(item.json.title || \"\");\n\n  if (seenUrls.has(url)) return false;\n  if (seenTitles.has(title)) return false;\n\n  seenUrls.add(url);\n  seenTitles.add(title);\n  return true;\n});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1632,
          -384
        ],
        "id": "a1878561-b321-41c6-92aa-67a0a0926625",
        "name": "Yİnelenen İçerik Filtresi"
      },
      {
        "parameters": {
          "jsCode": "// Gelen tüm json satırlarını tek bir dizi (array) içine alıyoruz\nconst allData = $input.all().map(item => item.json);\n\n// Vercel'in okuyabileceği ai_news.json formatına çeviriyoruz\nreturn [{ \n  json: { \n    fileContent: JSON.stringify(allData, null, 2) \n  } \n}];\n"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1328,
          224
        ],
        "id": "c855348f-c7a0-48af-9a94-110b6f9027ec",
        "name": "Code in JavaScript3"
      },
      {
        "parameters": {
          "jsCode": "// Eski haberleri HTTP Request node'undan (bir önceki adımdan) alıyoruz\nlet existingNews = [];\ntry {\n  existingNews = $input.all()[0].json; // GitHub'dan inen json verisi\n  if (!Array.isArray(existingNews)) {\n    existingNews = []; // Eğer dizi değilse veya boşsa sıfırla\n  }\n} catch (e) {\n  existingNews = [];\n}\n\n// Yeni haberleri \"Code in JavaScript2\" adlı node'dan çekiyoruz\n// NOT: Eğer sıralama yaptığınız node'un adı farklıysa aşağıdaki ismi güncelleyin.\nlet newNews = [];\ntry {\n  newNews = $items(\"Code in JavaScript2\").map(item => item.json);\n} catch (e) {\n  newNews = [];\n}\n\n// Eski ve yeni haberleri birleştir\n// (Sitenin çok yavaşlamaması için sadece son 60 haberi tutuyoruz)\nconst combinedNews = [...newNews, ...existingNews].slice(0, 60);\n\n// Vercel'e gönderilmek üzere formatla\nreturn [{ \n  json: { \n    fileContent: JSON.stringify(combinedNews, null, 2) \n  } \n}];\n"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          608,
          -128
        ],
        "id": "06eb1fb7-08c6-4f8a-9657-451066f3af69",
        "name": "Code in JavaScript4"
      },
      {
        "parameters": {
          "jsCode": "let existingNews = [];\ntry {\n  // GitHub Node'undan veriyi İKİLİ (Binary) olarak aldığınız için Base64 formatında gelir.\n  // Sizin belirlediğiniz \"json\" isimli ikili (binary) alandan veriyi okuyoruz:\n  const base64Data = $input.all()[0].binary.json.data;\n  \n  // Base64 şifresini çözerek normal metne (string) çeviriyoruz:\n  const rawData = Buffer.from(base64Data, 'base64').toString('utf8');\n  \n  // Metni JSON listesine dönüştürüyoruz\n  existingNews = JSON.parse(rawData);\n  \n  // Güvenlik: Eğer içerik düzgün bir dizi (array) değilse boş dizi yap\n  if (!Array.isArray(existingNews)) existingNews = [];\n} catch (e) {\n  // Dosya yoksa veya okunamadıysa sıfırdan başla\n  existingNews = [];\n}\n\n// YENİ HABERLERİ ALMA KISMI\nlet newNews = [];\ntry {\n  // Sıralama yaptığınız node'dan yeni haberleri çekiyoruz.\n  // DİKKAT: Node adınız \"Code in JavaScript2\" değilse, aşağıdaki ismi doğru node adıyla değiştirin!\n  newNews = $items(\"Code in JavaScript2\").map(item => item.json);\n} catch (e) {\n  newNews = [];\n}\n\n// Eski ve yeni haberleri birleştirip, sitenin hızlı çalışması için son 60'ını tutuyoruz\nconst combinedNews = [...newNews, ...existingNews].slice(0, 60);\n\n// GitHub Update node'una aktarılacak nihai JSON verisini string'e (metne) çeviriyoruz\nreturn [{ \n  json: { \n    fileContent: JSON.stringify(combinedNews, null, 2) \n  } \n}];\n"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          416,
          -128
        ],
