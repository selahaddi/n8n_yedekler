          "jsCode": "const allArticles = [];\n\n// Inputtan gelen her bir ana öğe için döngü\nfor (const item of $input.all()) {\n  const articles = item.json.articles;\n\n  // Eğer articles dizisi varsa, içindeki her bir makaleyi al\n  if (articles && Array.isArray(articles)) {\n    for (const article of articles) {\n      \n      // 'source' objesini dışarı çıkarıp düzleştirelim\n      const flattenedArticle = {\n        ...article,\n        source_id: article.source ? article.source.id : null,\n        source_name: article.source ? article.source.name : null\n      };\n      \n      delete flattenedArticle.source;\n\n      allArticles.push({ json: flattenedArticle });\n    }\n  }\n}\n\nreturn allArticles;"
        },
