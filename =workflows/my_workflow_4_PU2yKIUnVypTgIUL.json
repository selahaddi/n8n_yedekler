    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"urunler\": [\n    {\n      \"urun_kodu\": \"UR-001\",\n      \"urun_adi\": \"Tam Yağlı Süt 1L\",\n      \"kategori\": \"Süt Ürünleri\",\n      \"tedarikci\": \"Pınar Gıda\",\n      \"mevcut_stok\": 10,\n      \"minimum_stok\": 30,\n      \"son_30_gun_satis\": 120,\n      \"birim_fiyat\": 38.50,\n      \"siparis_durumu\": \"SİPARİŞ VER\",\n      \"siparis_adedi\": 170,\n      \"tahmini_maliyet\": 6545.00,\n      \"oncelik\": \"ACİL\",\n      \"gunluk_tuketim\": 4.00,\n      \"stok_gun_sayisi\": 2.50,\n      \"sebep\": \"Stok kritik seviyenin altında.\",\n      \"depo_bolgesi\": \"Soğuk Hava\",\n      \"koridor\": \"A\",\n      \"raf_no\": 3,\n      \"yerlesim_gerekcesi\": \"Çok satan A grubu soğuk zincir ürünü.\"\n    }\n  ]\n}"
      },
      "id": "82524690-b9b7-446f-98a3-ff1f3c4a46a5",
      "name": "Structured Output Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        -912,
        240
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = [];\n\nfor (const item of $input.all()) {\n  try {\n    const data = item.json.output || item.json;\n\n    if (data.urunler && Array.isArray(data.urunler)) {\n      for (const p of data.urunler) items.push({ json: p });\n    } else if (Array.isArray(data)) {\n      for (const p of data) items.push({ json: p });\n    } else if (data.urun_kodu) {\n      items.push({ json: data });\n    } else {\n      let content = typeof data === 'string' ? data : JSON.stringify(data);\n      content = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n      const match = content.match(/\\[\\s*\\{[\\s\\S]*\\}\\s*\\]/);\n      const parsed = JSON.parse(match ? match[0] : content);\n      if (Array.isArray(parsed)) for (const p of parsed) items.push({ json: p });\n      else items.push({ json: parsed });\n    }\n  } catch (err) {\n    console.error('Parse hatası:', err.message);\n    items.push({ json: { _hata: true, hata_detay: err.message, ham: JSON.stringify(item.json).substring(0, 300) } });\n  }\n}\n\nreturn items;"
      },
      "id": "49a5ae6f-25d6-4fee-b444-f739e19cbf42",
      "name": "AI Cevabını İşle",
