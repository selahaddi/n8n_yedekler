        "jsCode": "const item = $input.first().json;\nconst ad = (item.name || '').toLowerCase();\nconst mime = item.mimeType || '';\n\nconst gecerli =\n  ad.endsWith('.xlsx') ||\n  mime === 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet';\n\nif (!gecerli) {\n  throw new Error(`Geçersiz dosya: \"${item.name}\" — yalnızca .xlsx dosyaları işlenir.`);\n}\n\nreturn [{ json: { ...item, validasyon_gecti: true } }];"
