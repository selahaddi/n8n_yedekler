    },
    {
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "destinationFieldName": "tum_urunler",
        "options": {}
      },
      "id": "ee67f0c6-271f-4e42-9800-9a1e83d964f5",
      "name": "Tüm Sonuçları Topla",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [
        -576,
        128
      ]
    },
    {
      "parameters": {
        "jsCode": "const ham = $input.first().json.tum_urunler || [];\nconst urunler = ham.filter(u => !u._hata && u.urun_kodu);\nconst hataliSayisi = ham.filter(u => u._hata).length;\n\n// ── Sipariş listesi ──\nconst oncelikSira = { 'ACİL': 0, 'NORMAL': 1, 'YOK': 2 };\nconst siparisListesi = urunler\n  .filter(u => u.siparis_durumu === 'SİPARİŞ VER')\n  .sort((a, b) => (oncelikSira[a.oncelik] ?? 2) - (oncelikSira[b.oncelik] ?? 2));\n\n// ── Sayısal özetler ──\nconst acil    = urunler.filter(u => u.oncelik === 'ACİL').length;\nconst normal  = urunler.filter(u => u.oncelik === 'NORMAL').length;\nconst yeterli = urunler.filter(u => u.siparis_durumu === 'STOK YETERLİ').length;\nconst toplamMaliyet = siparisListesi.reduce((s, u) => s + (Number(u.tahmini_maliyet) || 0), 0);\n\n// ── Kategori özeti ──\nconst katMap = {};\nfor (const u of urunler) {\n  const k = u.kategori || 'Diğer';\n  if (!katMap[k]) katMap[k] = { acil: 0, normal: 0, yeterli: 0, maliyet: 0 };\n  if (u.oncelik === 'ACİL')        katMap[k].acil++;\n  else if (u.oncelik === 'NORMAL') katMap[k].normal++;\n  else                             katMap[k].yeterli++;\n  katMap[k].maliyet += Number(u.tahmini_maliyet) || 0;\n}\n\n// ── Tedarikçi özeti ──\nconst tedMap = {};\nfor (const u of siparisListesi) {\n  const t = u.tedarikci || 'Bilinmiyor';\n  if (!tedMap[t]) tedMap[t] = { urunler: [], maliyet: 0, acil: 0 };\n  tedMap[t].urunler.push(u.urun_adi);\n  tedMap[t].maliyet += Number(u.tahmini_maliyet) || 0;\n  if (u.oncelik === 'ACİL') tedMap[t].acil++;\n}\n\n// ── En kritik 5 ürün ──\nconst kritikTop5 = [...urunler]\n  .filter(u => u.stok_gun_sayisi != null)\n  .sort((a, b) => Number(a.stok_gun_sayisi) - Number(b.stok_gun_sayisi))\n  .slice(0, 5);\n\nreturn [{ json: {\n  siparis_listesi: siparisListesi,\n  tum_urunler: urunler,\n  kritik_top5: kritikTop5,\n  hatali_sayisi: hataliSayisi,\n  ozet: {\n    toplam_urun: urunler.length,\n    acil_siparis: acil,\n    normal_siparis: normal,\n    stok_yeterli: yeterli,\n    siparis_gereken_toplam: acil + normal,\n    tahmini_toplam_maliyet: Math.round(toplamMaliyet * 100) / 100,\n    rapor_tarihi: new Date().toLocaleString('tr-TR', { timeZone: 'Europe/Istanbul' })\n  },\n  kategori_ozeti: Object.entries(katMap).map(([k, v]) => ({\n    kategori: k, acil: v.acil, normal: v.normal, yeterli: v.yeterli,\n    maliyet_tl: Math.round(v.maliyet)\n  })),\n  tedarikci_ozeti: Object.entries(tedMap)\n    .sort((a, b) => b[1].maliyet - a[1].maliyet)\n    .map(([t, v]) => ({\n      tedarikci: t,\n      urun_sayisi: v.urunler.length,\n      urun_listesi: v.urunler.join(' | '),\n      acil_adet: v.acil,\n      toplam_maliyet_tl: Math.round(v.maliyet)\n    }))\n}}];"
      },
      "id": "bc4f5add-925a-4b35-82b2-941988ec3384",
      "name": "Rapor Verilerini Hazırla",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -336,
        128
      ]
    },
    {
      "parameters": {
        "jsCode": "// n8n'de tek bir Excel dosyasına birden fazla sheet yazmak için\n// binary veriyi base64 olarak üretip ileriki node'a aktarıyoruz.\n// SpreadsheetFile node'u tek sheet desteklediğinden bu yaklaşım gereklidir.\n\nconst d = $input.first().json;\n\n// ── SAYFA 1: Sipariş Listesi ──\nconst siparisRows = [[\n  'ÖNCELİK','ÜRÜN KODU','ÜRÜN ADI','KATEGORİ','TEDARİKÇİ',\n  'MEVCUT STOK','MİN. STOK','STOK (GÜN)','SON 30 GÜN SATIŞ',\n  'SİPARİŞ ADEDİ','BİRİM FİYAT (TL)','TAHMİNİ MALİYET (TL)','SEBEP'\n]];\nfor (const u of d.siparis_listesi) {\n  siparisRows.push([\n    u.oncelik, u.urun_kodu, u.urun_adi, u.kategori, u.tedarikci,\n    u.mevcut_stok, u.minimum_stok, u.stok_gun_sayisi, u.son_30_gun_satis,\n    u.siparis_adedi, u.birim_fiyat, u.tahmini_maliyet, u.sebep\n  ]);\n}\n\n// ── SAYFA 2: Yönetici Özeti ──\nconst ozetRows = [['BÖLÜM','METRİK','DEĞER']];\nozetRows.push(['▌ GENEL ÖZET','','']);\nozetRows.push(['','Toplam Ürün', d.ozet.toplam_urun]);\nozetRows.push(['','🔴 Acil Sipariş', d.ozet.acil_siparis]);\nozetRows.push(['','🟡 Normal Sipariş', d.ozet.normal_siparis]);\nozetRows.push(['','🟢 Stok Yeterli', d.ozet.stok_yeterli]);\nozetRows.push(['','💰 Toplam Maliyet (TL)', d.ozet.tahmini_toplam_maliyet]);\nozetRows.push(['','📅 Rapor Tarihi', d.ozet.rapor_tarihi]);\nozetRows.push(['','','']);\n\nozetRows.push(['▌ EN KRİTİK 5 ÜRÜN','Mevcut Stok','Stok (Gün)']);\nfor (const u of d.kritik_top5) {\n  ozetRows.push([u.urun_adi, u.mevcut_stok, u.stok_gun_sayisi]);\n}\nozetRows.push(['','','']);\n\nozetRows.push(['▌ KATEGORİ BAZLI ÖZET','Acil|Normal|Yeterli','Maliyet (TL)']);\nfor (const k of d.kategori_ozeti) {\n  ozetRows.push([k.kategori, `Acil:${k.acil}  Normal:${k.normal}  Yeterli:${k.yeterli}`, k.maliyet_tl]);\n}\nozetRows.push(['','','']);\n\nozetRows.push(['▌ TEDARİKÇİ SİPARİŞLERİ','Ürünler','Maliyet (TL)']);\nfor (const t of d.tedarikci_ozeti) {\n  const label = `${t.tedarikci} (${t.urun_sayisi} ürün${t.acil_adet > 0 ? ' ⚠️ ' + t.acil_adet + ' acil' : ''})`;\n  ozetRows.push([label, t.urun_listesi, t.toplam_maliyet_tl]);\n}\n\n// ── SAYFA 3: Depo Yerleşim Planı ──\nconst depoRows = [[\n  'DEPO BÖLGESİ','KORİDOR','RAF NO','ÜRÜN KODU','ÜRÜN ADI',\n  'KATEGORİ','SATIŞ HIZI','SON 30 GÜN','GÜNDELİK TÜKETİM','YERLEŞİM GEREKÇESİ'\n]];\nconst sortedDepo = [...d.tum_urunler].sort((a, b) => {\n  if ((a.depo_bolgesi||'') !== (b.depo_bolgesi||'')) return (a.depo_bolgesi||'').localeCompare(b.depo_bolgesi||'', 'tr');\n  if ((a.koridor||'') !== (b.koridor||'')) return (a.koridor||'').localeCompare(b.koridor||'');\n  return (a.raf_no||0) - (b.raf_no||0);\n});\nfor (const u of sortedDepo) {\n  const hiz = u.son_30_gun_satis > 100 ? 'Hızlı' : u.son_30_gun_satis >= 50 ? 'Orta' : 'Yavaş';\n  depoRows.push([u.depo_bolgesi, u.koridor, u.raf_no, u.urun_kodu, u.urun_adi,\n    u.kategori, hiz, u.son_30_gun_satis, u.gunluk_tuketim, u.yerlesim_gerekcesi]);\n}\n\n// Veriyi bir sonraki node'a geçir (SpreadsheetFile 3 ayrı çağrı yerine bu data kullanılacak)\nreturn [{ json: {\n  siparis_rows: siparisRows,\n  ozet_rows:    ozetRows,\n  depo_rows:    depoRows,\n  rapor_adi:    `Akilli_Depo_Raporu_${new Date().toISOString().slice(0,16).replace('T','_').replace(':','-')}.xlsx`,\n  ozet_data:    d.ozet,\n  tedarikci_ozeti: d.tedarikci_ozeti,\n  acil_urunler: d.siparis_listesi.filter(u => u.oncelik === 'ACİL')\n}}];"
      },
