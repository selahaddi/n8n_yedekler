  "nodes": [
    {
      "parameters": {
        "jsCode": "let content = $input.item.json.output || $input.item.json.text || '{}';\n\ntry {\n  // Eger yapay zeka yanitsal olarak basinda sonunda kod blogu gonderirse onlari temizliyoruz.\n  content = content.replace(/```json/g, '').replace(/```/g, '').trim();\n  const parsed = JSON.parse(content);\n  Object.assign($input.item.json, parsed);\n} catch (e) {\n  $input.item.json.error = \"JSON parse edilemedi: \" + e.message;\n}\n\nreturn $input.item;"
      },
      "id": "cd4408c8-be55-40ad-94fb-5bfe8dced6cb",
      "name": "JSON Ayrıştırma (Code)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        80
      ]
    },
    {
