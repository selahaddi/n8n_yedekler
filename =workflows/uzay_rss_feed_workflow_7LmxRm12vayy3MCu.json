    {
      "parameters": {
        "jsCode": "// 1. Son 1 haftanın tarihini hesapla\nconst oneWeekAgo = new Date();\noneWeekAgo.setDate(oneWeekAgo.getDate() - 7);\n\n// 2. Gelen tüm öğeleri al ve sırayla işlemlerden geçir\nconst processedItems = $input.all()\n  .filter(item => {\n      const data = item.json;\n      // Haberin tarihini JavaScript'in anlayacağı formata çevir\n      const itemDate = new Date(data.isoDate || data.pubDate);\n      \n      // Eğer haberin tarihi son 1 hafta içindeyse listeye dahil et (true döndür)\n      return itemDate >= oneWeekAgo; \n  })\n  .slice(0, 10) // 3. Filtreden geçen haberlerden SADECE İLK 10 tanesini al\n  .map(item => {\n      const data = item.json;\n      \n      // 4. Son kalan haberleri standart formata çevir\n      return {\n          json: {\n              source: \"NASA\", // Diğer node'larda burayı \"ESA\", \"Space.com\" vb. olarak değiştir\n              title: data.title,\n              date: data.isoDate || data.pubDate,\n              summary: data.contentSnippet || data.content || \"Özet bulunamadı.\",\n              url: data.link\n          }\n      };\n  });\n\n// Sonucu n8n'e döndür\nreturn processedItems;"
