    {
      "parameters": {
        "jsCode": "// AI Agent'tan gelen karmaşık yapıyı (output.haberler) düz listeye çevirir\nconst results = [];\nfor (const item of $input.all()) {\n  if (item.json.output && item.json.output.haberler) {\n    for (const haber of item.json.output.haberler) {\n      results.push({ json: haber });\n    }\n  }\n}\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1888,
        608
      ],
      "id": "b2a49e01-044e-47ed-84f8-ba81d6fbdaba",
      "name": "Code in JavaScript4"
    },
    {
      "parameters": {
        "jsCode": "// Gelen tüm haberleri tek bir HTML gövdesinde birleştiriyoruz\nlet htmlBody = `\n<div style=\"font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 600px; margin: auto; border: 1px solid #eee; padding: 20px; color: #333;\">\n  <h2 style=\"color: #2c3e50; text-align: center; border-bottom: 2px solid #3498db; padding-bottom: 10px;\">\n    🚀 Günlük Teknoloji Raporu - ${new Date().toLocaleDateString('tr-TR')}\n  </h2>\n`;\n\nfor (const item of $input.all()) {\n  // Eğer NewsAPI'den gelen görsel varsa onu kullan, yoksa şık bir placeholder göster\n  const imageUrl = item.json.url_image || 'https://via.placeholder.com/600x300?text=Teknoloji+Haberleri';\n\n  htmlBody += `\n    <div style=\"margin-bottom: 30px; padding: 0 0 20px 0; background-color: #fff; border-bottom: 1px solid #eee;\">\n      \n      <div style=\"width: 100%; margin-bottom: 15px;\">\n        <img src=\"${imageUrl}\" alt=\"${item.json.baslik}\" style=\"width: 100%; height: auto; border-radius: 8px; display: block; max-height: 300px; object-fit: cover;\">\n      </div>\n\n      <h3 style=\"margin-top: 0; color: #1a0dab; font-size: 18px;\">${item.json.baslik}</h3>\n      \n      <p style=\"color: #444; font-size: 14px; line-height: 1.6; margin-bottom: 15px;\">${item.json.ozet}</p>\n      \n      <div style=\"margin-top: 10px; margin-bottom: 15px;\">\n        <span style=\"background: #e1f5fe; color: #01579b; padding: 5px 10px; border-radius: 20px; font-size: 12px; font-weight: bold;\">\n          # ${item.json.kategori}\n        </span>\n        <span style=\"margin-left: 10px; color: #e67e22; font-weight: bold; font-size: 12px; border: 1px solid #e67e22; padding: 4px 8px; border-radius: 4px;\">\n          Önem Skoru: ${item.json.onem_skoru} / 10\n        </span>\n      </div>\n      \n      <a href=\"${item.json.url}\" target=\"_blank\" style=\"display: inline-block; padding: 10px 20px; background-color: #3498db; color: #ffffff; text-decoration: none; font-weight: bold; border-radius: 5px; font-size: 14px;\">\n        Haberin Tamamı →\n      </a>\n    </div>\n  `;\n}\n\nhtmlBody += `\n  <p style=\"text-align: center; color: #bdc3c7; font-size: 12px; margin-top: 30px;\">\n    Bu rapor n8n otomasyonu ve yapay zeka tarafından otomatik olarak derlenmiştir.<br>\n    © ${new Date().getFullYear()} Teknoloji Haber Servisi\n  </p>\n</div>\n`;\n\nreturn { html: htmlBody };"
      },
