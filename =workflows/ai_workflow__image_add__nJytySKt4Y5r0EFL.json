      "parameters": {
        "jsCode": "const allArticles = [];\n\n// Inputtan gelen her bir ana öğe (NewsAPI yanıtı) için döngü\nfor (const item of $input.all()) {\n  const articles = item.json.articles;\n\n  // Eğer articles dizisi varsa, içindeki her bir makaleyi işle\n  if (articles && Array.isArray(articles)) {\n    for (const article of articles) {\n      \n      // Haber verilerini düzleştiriyoruz\n      const flattenedArticle = {\n        ...article,\n        // Kaynak (source) bilgilerini düzleştir\n        source_id: article.source ? article.source.id : null,\n        source_name: article.source ? article.source.name : null,\n        \n        // GÖRSEL BURADA EKLENİYOR:\n        // NewsAPI'den gelen orijinal görsel linkini url_image adıyla kaydediyoruz\n        url_image: article.urlToImage ? article.urlToImage : null\n      };\n      \n      // Artık ihtiyacımız olmayan karmaşık objeyi siliyoruz\n      delete flattenedArticle.source;\n\n      // Temizlenmiş veriyi listeye ekle\n      allArticles.push({ json: flattenedArticle });\n    }\n  }\n}\n\nreturn allArticles;"
      },
